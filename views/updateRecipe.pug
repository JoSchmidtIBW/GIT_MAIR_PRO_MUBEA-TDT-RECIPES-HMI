            function checkNext(){
                console.log("bin checkNext");
                const saveRecipe = document.getElementById('saveRecipe');
                const checkNext = document.getElementById('checkNext');

                const dornDurchmesserInputs = document.querySelectorAll('.dornDurchmesser');
                console.log("-----------------------------------: " + dornDurchmesserInputs)
                let previousDornDurchmesser = -Infinity;
                
                const dornPositionInputs = document.querySelectorAll('.position');
