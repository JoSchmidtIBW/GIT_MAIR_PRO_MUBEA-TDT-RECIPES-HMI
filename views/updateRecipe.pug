extends base

block content
    main.main
        br
        .user-view
            .user-view__content
                .user-view__form-container
                    h1.heading-secondary.ma-bt-md=`${data.kopfDaten.artikelNummer}- Recipe edit  `
                        |
                        svg(class="heading-box__icon" style="margin-left: 0px; margin-bottom: -3px; height: 24px; length: 24px;")
                            use(xlink:href="/img/icons.svg#icon-edit" style="color: green; ")
                    form.form.form-updateRecipe-data
                        input#recipeID(type="hidden", value=data._id readOnly=true, style="background-color: lightgreen; width: 190px;")                        
                        div(class="form__group") Header- Data
                            label(class="form__label", for="artikelNummer") Itemnumber 
                            input#artikelNummer(class="form__input", type="number", value=data.kopfDaten.artikelNummer, readOnly=true, style="background-color: #E8F0FE;")
                        div(class="form__group ma-bt-md")
                            label(class="form__label", for="artikelName") Productname
                            input#artikelName(class="form__input", type="text", value=data.kopfDaten.artikelName, readOnly=true, style="background-color: #E8F0FE;")
                        div(class="form__group ma-bt-md")
                            label(class="form__label", for="ziehGeschwindigkeit") Drawing- speed (m/min)
                            input#ziehGeschwindigkeit(class="form__input", type="number", value=data.kopfDaten.ziehGeschwindigkeit, readOnly=true, style="background-color: #E8F0FE;")
                        div(class="form__group ma-bt-md")
                            button.btn.btn--info-big.toggle-recipe-Kopfdaten-Verlauf-button(type="button" style="margin-left: 0px; margin-top: 4px; ")
                                svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 24px; length: 24px;")
                                    use(xlink:href="/img/icons.svg#icon-arrow-down" style="color: green; ")
                                a(style="color: green; margin-top: 0px; margin-bottom: 16px; margin-left: 1px; margin-right: 5px; vertical-align: middle; display: inline-block; ")  Course
                            a
                                .recipe-Kopfdaten-Verlauf-container(style="display: none;")
                                    br
                                    div(class="form__group") Course
                                        each kommentar in data.kopfDaten.kommentar
                                            - const formattedDate = new Date(kommentar.erstelltAm).toLocaleString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });
                                            br
                                            div#kommentarContainer(class="form__input", style="background-color: #f7f7f7;  padding: 4px; display: flex; width: 100%;") 
                                                input#kommentarID(type="hidden", value=kommentar._id readOnly=true, style="background-color: lightgreen; width: 190px;")
                                                textarea(readonly, style="background-color: white; font-size: 16px; color: blue;  width: 350px; height: 60px;")= `${kommentar.kommentarBeschreibung}`
                                                div(style="flex: 1; margin-left: 10px; width: 100%; border: 1px solid #c3c3c3;")
                                                    a(style="font-size: 14px; color: black;") #{kommentar.createdBy.firstName} #{kommentar.createdBy.lastName}
                                                    br
                                                    a(style="font-size: 12px; color: green;") #{formattedDate}
                            script.
                                function myComment() {
                                    let commentDropdown = document.getElementById('commentDropdown');
                                    let customCommentInput = document.getElementById('customCommentInput');

                                    if (commentDropdown.value === 'custom') {
                                        customCommentInput.style.display = 'block';
                                        customCommentInput.setAttribute('required', 'required');
                                    } else {
                                        customCommentInput.style.display = 'none';
                                        customCommentInput.removeAttribute('required');
                                        customCommentInput.value = '';
                                    }
                                } 
                            br
                        label(class="form__label", for="bearbeitenderBenutzer")= `Editing user: ${user.firstName} ${user.lastName}`
                            input#userID(type="hidden", value=user._id readOnly=true, style="background-color: lightgreen; width: 190px;")
                            input#userNewDate(type="hidden", value=new Date, readOnly=true, style="background-color: lightgreen; width: 190px;")
                            br
                        label(class="form__label")    
                            label(class="form__label", for="myComment")=`Editing- description`
                            select#commentDropdown(class="form__input", onchange="myComment()")
                                option(value="Ecken angepasst") Corner adjusted
                                option(value="Dorn-Geschwindigkeit angepasst") Thorn- Speed adjusted 
                                option(value="Dornmasse geändert") Thorn values adjusted
                                option(value="Angel geändert") Tube- rod changed
                                option(value="custom") Enter your own comment... 
                            script.
                                function checkCapsLock(event) {
                                    var capsLockWarning = document.getElementById("capsLockWarning");
                                    if (event.getModifierState("CapsLock")) {
                                        capsLockWarning.style.display = "block";
                                    } else {
                                        capsLockWarning.style.display = "none";
                                    }
                                }
                            input#customCommentInput(type="text", class="form__input", placeholder="Write something here...", style="display: none; background-color: #f7f7f7", onkeypress="checkCapsLock(event)")
                            span#capsLockWarning(style="display: none; color: red;") Caps Lock is activated!
                            br

                        div(class="form__group")
                            label(class="form__label", for="vDornVor") Thorn-speed forward (%)
                            input#vDornVor(class="form__input", type="number", placeholder='zB. 100', value=data.kopfDaten.v_dorn_Fwd, required="required" min="1" max="100" onblur="validateVDornVor(this)")
                            //div(class="form__group")
                            label(class="form__label", for="vDornZurueck") Thorn-speed backward (%)
                            input#vDornZurueck(class="form__input", type="number", placeholder='zB. 100', value=data.kopfDaten.v_dorn_Bwd, required="required" min="1" max="100" onblur="validateVDornZurueck(this)")
                                 

                        if (user.role === 'admin' || user.role === 'Chef')
                            button.btn.btn--info-big.toggle-recipe-Kopfdaten-button(type="button" style="margin-left: 0px; margin-top: 4px; ")
                                svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 24px; length: 24px;")
                                    use(xlink:href="/img/icons.svg#icon-arrow-down" style="color: green; ")
                                a(style="color: green; margin-top: 0px; margin-bottom: 16px; margin-left: 1px; margin-right: 5px; vertical-align: middle; display: inline-block; ")  Additional header-data
                            br
                            .recipe-Kopfdaten-container(style="display: none;")
                                br
                                div(class="form__group ma-bt-md")
                                    label(class="form__label", for="teileNummer" style="color: green;") Partnumber
                                    input#teileNummer(class="form__input", type="text", placeholder=`${data.kopfDaten.teileNummer || 'MTTXXXXXXXXX (is standard)'}`, value=data.kopfDaten.teileNummer, style="background-color: #ECFFDC;")
                                div(class="form__group ma-bt-md")
                                    label(class="form__label", for="zeichnungsNummer" style="color: green;") Blueprint-number
                                    input#zeichnungsNummer(class="form__input", type="text", placeholder=`${data.kopfDaten.zeichnungsNummer || 'MTTXXXXXXXXX (is standard)'}`, value=data.kopfDaten.zeichnungsNummer, style="background-color: #ECFFDC;")    
                                div(class="form__group ma-bt-md")
                                    label(class="form__label", for="aenderungsstandZeichnung" style="color: green;") Change-blueprint-status
                                    input#aenderungsstandZeichnung(class="form__input", type="number", placeholder=`${data.kopfDaten.aenderungsstandZeichnung || '1 (is standard)'}`, value=data.kopfDaten.aenderungsstandZeichnung, style="background-color: #ECFFDC;")    
                                div(class="form__group ma-bt-md")
                                    label(class="form__label", for="aenderungsstandRezept" style="color: green;") Change-recipe-status
                                    input#aenderungsstandRezept(class="form__input", type="number", placeholder=`${data.kopfDaten.aenderungsstandRezept  || '1 (is standard)'}`, value=data.kopfDaten.aenderungsstandRezept, style="background-color: #ECFFDC;")    
                                div(class="form__group ma-bt-md")
                                    label(class="form__label", for="beschreibung" style="color: green;") Description
                                    input#beschreibung(class="form__input", type="text", placeholder=`${data.kopfDaten.beschreibung || 'irgendwas (is standard)'}`, value=data.kopfDaten.beschreibung, style="background-color: #ECFFDC;")
                        else 
                            button.btn.btn--info-big.toggle-recipe-Kopfdaten-button(type="button" style="margin-left: 0px; margin-top: 4px; display: none;")
                            .recipe-Kopfdaten-container(style="display: none;")
                            input#teileNummer(class="form__input", type="text", value=data.kopfDaten.teileNummer, style="background-color: #ECFFDC; display: none;", readOnly=true)
                            input#zeichnungsNummer(class="form__input", type="text", value=data.kopfDaten.zeichnungsNummer, style="background-color: #ECFFDC; display: none;", readOnly=true)    
                            input#aenderungsstandZeichnung(class="form__input", type="number", value=data.kopfDaten.aenderungsstandZeichnung, style="background-color: #ECFFDC; display: none;", readOnly=true)  
                            input#aenderungsstandRezept(class="form__input", type="number", value=data.kopfDaten.aenderungsstandRezept, style="background-color: #ECFFDC; display: none;", readOnly=true)      
                            input#beschreibung(class="form__input", type="text", value=data.kopfDaten.beschreibung, style="background-color: #ECFFDC; display: none;", readOnly=true)
                        br
                        br        
                        div(class="form__group") Thorn- Values
                            div#div-Toggle-ExampleImg-TDTAuftragMitVorzug-button(style="display: flex;  align-items: center; justify-content: space-between;")                                       
                                //label(class="form__label_2", for="rohrAussenDurchmesserLetzterZug" style="color: green;")
                                label(class="form__label", for="rohrAussenDurchmesserLetzterZug" style="color: green;")
                                    | Active-material-tube outer- Diameter
                                    span.form__label-diameter-symbol &empty; (mm)
                                    |   (OD-last draw --> mind last draw!)  
                                button.btn.btn--info.toggle-ExampleImg-TDTAuftragMitVorzug-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-TDTAuftragMitVorzug-container(style="display: none;")
                                div(class="form__group") Example
                                    img#imgTDTAuftragMitVorzug(src='/img/RezepteBilderASMAG/TDTAuftragMitVorzug.png', alt='img TDTAuftragMitVorzug')
                                    br    
                                    br                                       
                            input#rohrAussenDurchmesserLetzterZug(class="form__input", placeholder="e.g. 41.00", required="required", type="text", value=parseFloat(data.dornWerte.rohrAussenDurchmesserLetzterZug).toFixed(2), onblur="validateRohrAussenDurchmesserLetzterZug(this)")    
                        div(class="form__group")
                            label(class="form__label", for="rohrInnenDurchmesserLetzterZug" style="color: green;") Tube- inner-diameter- last draw calculated (mm) (Outer-diameter - 2 x wall-thickness last draw)
                            input#rohrInnenDurchmesserLetzterZug(class="form__input", required="required", placeholder="e.g. 26.00", type="text", value=parseFloat(data.dornWerte.rohrInnenDurchmesserLetzterZug).toFixed(2), onblur="validateRohrInnenDurchmesserLetzterZug(this)")
                        div(class="form__group")
                            div#div-Toggle-ExampleImg-BeispielAngel-button(style="display: block;  align-items: center; justify-content: space-between;")                                                
                                label(class="form__label_2", for="angel" style="color: green;") Tube- rod (mm)
                                button.btn.btn--info.toggle-ExampleImg-BeispielAngel-button(type="button" style="margin-left: 428px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-BeispielAngel-container(style="display: none;")
                                div(class="form__group") Example
                                    img#imgBeispielAngel(src='/img/RezepteBilderASMAG/BeispielAngel.png', alt='img BeispielAngel')
                                    br    
                                    br    
                            input#angel(class="form__input", required="required", type="number", value=data.dornWerte.angel, placeholder="150 (is standard)", min="150" max="1000", onblur="validateAngel(this)")                             
                        div(class="form__group")
                            label(class="form__label", for="rohrAussenDurchmesserTDTZug" style="color: green;") Tube- outer- diameter- TDT- draw (mm)
                            input#rohrAussenDurchmesserTDTZug(class="form__input", type="text", value=parseFloat(data.dornWerte.rohrAussenDurchmesserTDTZug).toFixed(2), readOnly=true, style="background-color: #E8F0FE;")    
                        br                         
                        each stufe, index in data.dornWerte.dornStufen.dornStufe
                            br
                            .dornStufen-Container
                                input.stufeID(type="hidden", value=stufe._id, readOnly=true, style="background-color: lightgreen; width: 190px;")
                                div(class="form__group") Thorn- Steps
                                    if(data.dornWerte.dornStufen.dornStufe.length===3)
                                        if(index===0)
                                            div#div-Toggle-ExampleImg-DornDurchmesserErsteStufe-button(style="display: block;  align-items: center; justify-content: space-between;")                                                
                                                label(class="form__label_2", for="dornDurchmesser" style="color: green;") Thorn- diameter first step (mm)
                                                button.btn.btn--info.toggle-ExampleImg-DornDurchmesserErsteStufe-button(type="button" style="margin-left: 312px; margin-bottom: 10px; ")
                                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                                            .exampleImg-DornDurchmesserErsteStufe-container(style="display: none;")
                                                div(class="form__group") Example
                                                    img#imgDornDurchmesserErsteStufe(src='/img/RezepteBilderASMAG/DornDurchmesserErsteStufe3STD.png', alt='img DornDurchmesserErsteStufe3STD')
                                                    br    
                                                    br                                                                           
                                            input.dornDurchmesser(class="form__input", required="required", placeholder=`${parseFloat(stufe.dornDurchmesser).toFixed(2)}`, type="text", value=parseFloat(stufe.dornDurchmesser).toFixed(2), onblur="validateDornDurchmesser(this)", pattern="^(0[1-9]|[1-9][0-9]|1[0-9][0-9])[.](0[0-9]|1[0-9]|[2-9][0-9])$")
                                        else if(index===1)
                                            div#div-Toggle-ExampleImg-DornDurchmesserZweiteStufe-button(style="display: block;  align-items: center; justify-content: space-between;")                                                
                                                label(class="form__label_2", for="dornDurchmesser" style="color: green;") Thorn- diameter second step (mm)
                                                button.btn.btn--info.toggle-ExampleImg-DornDurchmesserZweiteStufe-button(type="button" style="margin-left: 291px; margin-bottom: 10px; ")
                                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                                            .exampleImg-DornDurchmesserZweiteStufe-container(style="display: none;")
                                                div(class="form__group") Example
                                                    img#imgDornDurchmesserZweiteStufe(src='/img/RezepteBilderASMAG/DornDurchmesserZweiteStufe3STD.png', alt='img DornDurchmesserZweiteStufe3STD')
                                                    br    
                                                    br                                                                           
                                            input.dornDurchmesser(class="form__input", required="required", placeholder=`${parseFloat(stufe.dornDurchmesser).toFixed(2)}`, type="text", value=parseFloat(stufe.dornDurchmesser).toFixed(2), onblur="validateDornDurchmesser(this)", pattern="^(0[1-9]|[1-9][0-9]|1[0-9][0-9])[.](0[0-9]|1[0-9]|[2-9][0-9])$")
                                        else if(index===2) 
                                            div#div-Toggle-ExampleImg-DornDurchmesserDritteStufe-button(style="display: block;  align-items: center; justify-content: space-between;")                                                                          
                                                label(class="form__label_2", for="dornDurchmesser" style="color: green;") Thorn- diameter third step (mm)
                                                button.btn.btn--info.toggle-ExampleImg-DornDurchmesserDritteStufe-button(type="button" style="margin-left: 307px; margin-bottom: 10px; ")
                                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                                            .exampleImg-DornDurchmesserDritteStufe-container(style="display: none;")
                                                div(class="form__group") Example
                                                    img#imgDornDurchmesserDritteStufe(src='/img/RezepteBilderASMAG/DornDurchmesserDritteStufe3STD.png', alt='img DornDurchmesserDritteStufe3STD')
                                                    br    
                                                    br                                                                           
                                            input.dornDurchmesser(class="form__input", required="required", placeholder=`${parseFloat(stufe.dornDurchmesser).toFixed(2)}`, type="text", value=parseFloat(stufe.dornDurchmesser).toFixed(2), onblur="validateDornDurchmesser(this)", pattern="^(0[1-9]|[1-9][0-9]|1[0-9][0-9])[.](0[0-9]|1[0-9]|[2-9][0-9])$")
                                    else 
                                        div#div-Toggle-ExampleImg-DornDurchmesserDritteStufe-button(style="display: none;  align-items: center; justify-content: space-between;")                                                
                                                label(class="form__label", for="dornDurchmesser" style="color: green;") Dorn- Durchmesser zur Dritteeee Stufe (mm) validate machen bei durchmesser Position
                                                button.btn.btn--info.toggle-ExampleImg-DornDurchmesserDritteStufe-button(type="button" style="margin-left: 451px; margin-bottom: 10px; ")
                                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                                        .exampleImg-DornDurchmesserDritteStufe-container(style="display: none;")
                                                div(class="form__group") Example
                                                    img#imgDornDurchmesserDritteStufe(src='/img/RezepteBilderASMAG/DornDurchmesserDritteStufe3STD.png', alt='img DornDurchmesserDritteStufe3STD')
                                                    br    
                                                    br                                                                           
                                        if(index===0)
                                            div#div-Toggle-ExampleImg-DornDurchmesserErsteStufe-button(style="display: block;  align-items: center; justify-content: space-between;")                                                
                                                label(class="form__label_2", for="dornDurchmesser" style="color: green;") Thorn diameter first step (mm)
                                                button.btn.btn--info.toggle-ExampleImg-DornDurchmesserErsteStufe-button(type="button" style="margin-left: 318px; margin-bottom: 10px; ")
                                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                                            .exampleImg-DornDurchmesserErsteStufe-container(style="display: none;")
                                                div(class="form__group") Example
                                                    img#imgDornDurchmesserErsteStufe(src='/img/RezepteBilderASMAG/DornDurchmesserErsteStufe.png', alt='img DornDurchmesserErsteStufe')
                                                    br    
                                                    br                                                                           
                                            input.dornDurchmesser(class="form__input", required="required", placeholder=`${parseFloat(stufe.dornDurchmesser).toFixed(2)}`, type="text", value=parseFloat(stufe.dornDurchmesser).toFixed(2), onblur="validateDornDurchmesser(this)", pattern="^(0[1-9]|[1-9][0-9]|1[0-9][0-9])[.](0[0-9]|1[0-9]|[2-9][0-9])$")
                                        else if (index===1)
                                            div#div-Toggle-ExampleImg-DornDurchmesserZweiteStufe-button(style="display: block;  align-items: center; justify-content: space-between;")                                                
                                                label(class="form__label_2", for="dornDurchmesser" style="color: green;") Thorn diameter second step (mm)
                                                button.btn.btn--info.toggle-ExampleImg-DornDurchmesserZweiteStufe-button(type="button" style="margin-left: 295px; margin-bottom: 10px; ")
                                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                                            .exampleImg-DornDurchmesserZweiteStufe-container(style="display: none;")
                                                div(class="form__group") Example
                                                    img#imgDornDurchmesserZweiteStufe(src='/img/RezepteBilderASMAG/DornDurchmesserZweiteStufe.png', alt='img DornDurchmesserZweiteStufe')
                                                    br    
                                                    br                                                                           
                                            input.dornDurchmesser(class="form__input", required="required", placeholder=`${parseFloat(stufe.dornDurchmesser).toFixed(2)}`, type="text", value=parseFloat(stufe.dornDurchmesser).toFixed(2), onblur="validateDornDurchmesser(this)", pattern="^(0[1-9]|[1-9][0-9]|1[0-9][0-9])[.](0[0-9]|1[0-9]|[2-9][0-9])$")
                                div(class="form__group") 
                                    if(data.dornWerte.dornStufen.dornStufe.length===3)
                                        if(index===0)
                                            label(class="form__label", for="position" style="color: green;") Thorn position first step (mm)
                                            if(stufe.position===0)
                                                input.position(class="form__input", readOnly= true, required="required", placeholder="+ 1 bis 2mm zusätzlich länger beim Dornbereich der dünneren Wanddicke", type="number", value=stufe.position, style="background-color: #E8F0FE;", onblur="validateDornPosition(this)")                                               
                                        else if(index===1)
                                            div#div-Toggle-ExampleImg-DornPositionZweiteStufe-button(style="display: block;  align-items: center; justify-content: space-between;")                                                
                                                label#labelDornPositionZweiteStufe(class="form__label_2", for="dornPositionZweiteStufe", style="color: green;") Thorn- Position second step (mm) --> Measure the thorn with a ruler...!   
                                                button.btn.btn--info.toggle-ExampleImg-DornPositionZweiteStufe-button(type="button" style="margin-left: 34px; margin-bottom: 10px; ")
                                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
