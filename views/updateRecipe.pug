                const eckeXPositionInputs = document.querySelectorAll('.eckeXPosition');
                let previousEckenPosition = -Infinity; // Anfangswert, der kleiner als die kleinste Position ist

                for (let i = 0; i < dornDurchmesserInputs.length; i++) {
                    const currentDornDurchmesser = parseFloat(dornDurchmesserInputs[i].value);
                    console.log("currentDornDurchmesser: "+currentDornDurchmesser)

                    if (currentDornDurchmesser <= previousDornDurchmesser) {
