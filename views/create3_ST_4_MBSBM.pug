extends base

block content 
    main.main 
        br
        .user-view
            .user-view__content
                .user-view__form-container
                    h2.heading-secondary.ma-bt-md Create three-thorn-steps-4-MBSBM-recipe
                    form.form.form-createRecipe-3_St_4_MBSBM-data
                        div(class="form__group")
                            .boxImg_CreateTemplate
                                img#img3_St_4_MBSBM_CreateTemplate(style="height: 200px; length: 400px; margin-left: 5px; margin-top: 5px; margin-bottom: 1px; margin-right: 5px;" src='/img/RezepteBilderASMAG/3_St_4_MBSBM_CreateVorlage.png', alt='img 3_St_4_MBSBM_CreateVorlage2')
                        div(class="form__group") Header- Data
                            label(class="form__label", for="artikelNummer") Itemnumber                            
                            input#artikelNummer(class="form__input" type="number" placeholder="e.g. 10191122" required="required" min="10000000" max="99999999" onblur="validateArtikelNummer(this)")
                        div(class="form__group")
                            label(class="form__label", for="artikelName") Productname
                            input#artikelName(class="form__input", type="text", placeholder="e.g. 24.50x3.80-3.20-2.60", required="required", pattern="^\\d{2}\\.\\d{2}x\\d\\.\\d{2}-\\d\\.\\d{2}-\\d\\.\\d{2}$", onblur="validateArtikelName(this)")
                        div(class="form__group")
                            label(class="form__label", for="ziehGeschwindigkeit") Drawing- speed (m/min)
                            input#ziehGeschwindigkeit(class="form__input", type="number", placeholder="e.g. 15",required="required" min="5" max="50" onblur="validateZiehGeschwindigkeit(this)")
                        
                        div(class="form__group")
                            label(class="form__label", for="vDornVor") Thorn- speed forward (%)
                            input#vDornVor(class="form__input", type="number", placeholder="e.g. 100", required="required" min="1" max="100" onblur="validateVDornVor(this)")
                            //div(class="form__group")
                            label(class="form__label", for="vDornZurueck") Thorn- speed backward (%)
                            input#vDornZurueck(class="form__input", type="number", placeholder="e.g. 100", required="required" min="1" max="100" onblur="validateVDornZurueck(this)")                                                                                                   
                        
                        div(class="form__group")
                            //-br
                            br
                            label(class="form__label", for="benutzerVorName") Firstname
                            input#benutzerID(class="form__input" type="hidden" value=user._id style="background-color: lightgreen;")
                            input#benutzerVorName(class="form__input" type="text" value=user.firstName readOnly=true style="background-color: #E8F0FE;")
                            br
                            label(class="form__label", for="benutzerNachName") Secondname
                            input#benutzerNachName(class="form__input" type="text" value=user.lastName readOnly=true style="background-color: #E8F0FE;") 
                        div(class="form__group")
                            button.btn.btn--green(id="nextButtonKopfdaten" type="button" onclick="saveDataKopfDaten()") Next
                            a.btn-space
                            a.btn-space
                            a.btn.btn--small.btn--gray(href=`/api/v1/createRecipeOverview` id="cancelButtonKopfdaten") Cancel
                        
                        div(class="form__group") Thorn- Values
                            div#div-Toggle-ExampleImg-TDTAuftragMitVorzug-button(style="display: none;  align-items: center; justify-content: space-between;")                        
                                label#labelRohrAussenDurchmesserLetzterZug(class="form__label", for="rohrAussenDurchmesserLetzterZug" )
                                    | Active-material-tube outer- Diameter
                                    span.form__label-diameter-symbol &empty; (mm)
                                    |   (OD-last draw --> mind last draw!)
                                button.btn.btn--info.toggle-ExampleImg-TDTAuftragMitVorzug-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-TDTAuftragMitVorzug-container(style="display: none;")
                                div(class="form__group") Example
                                    img#imgTDTAuftragMitVorzug(src='/img/RezepteBilderASMAG/TDTAuftragMitVorzug.png', alt='img TDTAuftragMitVorzug')
                                    br    
                                    br           
                            input#rohrAussenDurchmesserLetzterZug(class="form__input", type="text", placeholder="e.g. 41.00 (mind last draw! e.g. 31.00)",style="display: none;", required="required", pattern="^(0[1-9]|[1-9][0-9]|1[0-9][0-9])[.](0[0-9]|1[0-9]|[2-9][0-9])$", onblur="validateRohrAussenDurchmesserLetzterZug(this)")
                        div(class="form__group")
                            label#labelRohrWandDickeAussenDurchmesserLetzterZug(class="form__label", for="rohrWandDickeAussenDurchmesserLetzterZug" style="display: none;")
                                | Active-material-tube wall-thickness (mm)
                                |   (WT-last Draw --> mind last draw!) 
                            input#rohrWandDickeAussenDurchmesserLetzterZug(class="form__input", type="text", placeholder="e.g. 5.60 (mind last draw! e.g. 4.20)",style="display: none;", required="required", pattern="^(0?[1-9]|9)[.](0[0-9]|1[0-9]|[2-9][0-9])$", onblur="validateRohrWandDickeAussenDurchmesserLetzterZug(this)")
                        div(class="form__group")
                            label#labelRohrInnenDurchmesserLetzterZugBerechnet(class="form__label", for="rohrInnenDurchmesserLetzterZugBerechnet" style="display: none;") Tube- inner-diameter- last draw calculated (mm) (Outer-diameter - 2 x wall-thickness last draw)
                            input#rohrInnenDurchmesserLetzterZugBerechnet(class="form__input", type="number", style="display: none;", required="required")     
                        div(class="form__group")
                            label#labelRohrAussenDurchmesserTDTZug(class="form__label", for="rohrAussenDurchmesserTDTZug" style="display: none;") Tube- outer- diameter- TDT- draw (mm)
                            input#rohrAussenDurchmesserTDTZug(class="form__input", type="number", style="display: none;", required="required")
                        div(class="form__group")
                            div#div-Toggle-ExampleImg-BeispielAngel-button(style="display: none;  align-items: center; justify-content: space-between;")                                                
                                label#labelAngel(class="form__label", for="angel") Tube- rod (mm)
                                button.btn.btn--info.toggle-ExampleImg-BeispielAngel-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-BeispielAngel-container(style="display: none;")
                                div(class="form__group") Example
                                    img#imgBeispielAngel(src='/img/RezepteBilderASMAG/BeispielAngel.png', alt='img BeispielAngel')
                                    br    
                                    br                               
                            input#angel(class="form__input", type="number", placeholder="150 (is standard)",style="display: none;", required="required", min="150" max="1000", onblur="validateAngel(this)")    
                            br
                            br
                        div(class="form__group" id="groupDornWerte1Button" style="display: none;")
                            button.btn.btn--green(id="nextButtonDornWerte1" type="button" onclick="saveDataDornWerte1()" ) Next
                            a.btn-space
                            a.btn-space
                            a.btn.btn--small.btn--gray(href=`/api/v1/createRecipeOverview` id="cancelButtonDornWerte1") Cancel
                        
                        div(class="form__group") Thorn- Steps
                            div#div-Toggle-ExampleImg-DornDurchmesserErsteStufe-button(style="display: none;  align-items: center; justify-content: space-between;")                                                
                                label#labelDornDurchmesserErsteStufe(class="form__label", for="dornDurchmesserErsteStufe")= `Thorn- diameter first22222 step (theoretically: ${dornDurchmesserErsteStufeBerechnet} )`
                                button.btn.btn--info.toggle-ExampleImg-DornDurchmesserErsteStufe-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-DornDurchmesserErsteStufe-container(style="display: none;")
                                div(class="form__group") Example
                                    img#imgDornDurchmesserErsteStufe(src='/img/RezepteBilderASMAG/DornDurchmesserErsteStufe3STD.png', alt='img DornDurchmesserErsteStufe3STD')
                                    br    
                                    br                                                             
                            input#dornDurchmesserErsteStufe(class="form__input", type="text", style="display: none;" placeholder="Smallest diameter",required="required"  pattern="^(0[1-9]|[1-9][0-9]|1[0-9][0-9])[.](0[0-9]|1[0-9]|[2-9][0-9])$" onblur="validateDornDurchmesserErsteStufe(this)")        
                        div(class="form__group")
                            label#labelDornPositionErsteStufe(class="form__label", for="dornPositionErsteStufe" style="display: none;") Thorn- position first step (mm)
                            input#dornPositionErsteStufe(class="form__input", type="number",readOnly = true, style="display: none;" placeholder="",required="required" value='0' min="0" max="0" )
                        div(class="form__group")
                            div#div-Toggle-ExampleImg-DornDurchmesserZweiteStufe-button(style="display: none;  align-items: center; justify-content: space-between;")                                                    
                                label#labelDornDurchmesserZweiteStufe(class="form__label", for="dornDurchmesserZweiteStufe")= `Thorn- diameter second step (mm) (theoretically: ${dornDurchmesserZweiteStufeBerechnet} )`
                                button.btn.btn--info.toggle-ExampleImg-DornDurchmesserZweiteStufe-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-DornDurchmesserZweiteStufe-container(style="display: none;")
                                div(class="form__group") Example
                                    img#imgDornDurchmesserZweiteStufe(src='/img/RezepteBilderASMAG/DornDurchmesserZweiteStufe3STD.png', alt='img DornDurchmesserZweiteStufe3STD')
                                    br    
                                    br                              
                            input#dornDurchmesserZweiteStufe(class="form__input", type="text", style="display: none;" placeholder="Middle diameter",required="required", pattern="^(0[1-9]|[1-9][0-9]|1[0-9][0-9])[.](0[0-9]|1[0-9]|[2-9][0-9])$" onblur="validateDornDurchmesserZweiteStufe(this)")    
                        div(class="form__group")
                            div#div-Toggle-ExampleImg-DornPositionZweiteStufe-button(style="display: none;  align-items: center; justify-content: space-between;")                                                
                                label#labelDornPositionZweiteStufe(class="form__label", for="dornPositionZweiteStufe") Thorn- Position second step (mm) --> Measure the thorn with a ruler...!  
                                button.btn.btn--info.toggle-ExampleImg-DornPositionZweiteStufe-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-DornPositionZweiteStufe-container(style="display: none;")
                                div(class="form__group") Example
                                    img#imgDornPositionZweiteStufe(src='/img/RezepteBilderASMAG/DreiStufenDornMessenErsteBisM.png', alt='img DreiStufenDornMessenErsteBisM')
                                    br    
                                    br                                 
                            input#dornPositionZweiteStufe(class="form__input", type="number", style="display: none;" placeholder="e.g. 35 (+ 1mm to 2mm additionally longer in the thorn-area of middle wall thickness)",required="required" min="10" max="99" onblur="validateDornPositionZweiteStufe(this)")                                    
                        div(class="form__group")
                            div#div-Toggle-ExampleImg-DornDurchmesserDritteStufe-button(style="display: none;  align-items: center; justify-content: space-between;")                                                    
                                label#labelDornDurchmesserDritteStufe(class="form__label", for="dornDurchmesserZweiteStufe")= `Thorn- diameter third step (mm) (theoretically: ${dornDurchmesserDritteStufeBerechnet} )`
                                button.btn.btn--info.toggle-ExampleImg-DornDurchmesserDritteStufe-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-DornDurchmesserDritteStufe-container(style="display: none;")
                                div(class="form__group") Example
                                    img#imgDornDurchmesserDritteStufe(src='/img/RezepteBilderASMAG/DornDurchmesserDritteStufe3STD.png', alt='img DornDurchmesserDritteStufe3STD')
                                    br    
                                    br                                 
                            input#dornDurchmesserDritteStufe(class="form__input", type="text", style="display: none;" placeholder="Biggest diameter",required="required", pattern="^(0[1-9]|[1-9][0-9]|1[0-9][0-9])[.](0[0-9]|1[0-9]|[2-9][0-9])$" onblur="validateDornDurchmesserDritteStufe(this)")    
                        div(class="form__group")
                            div#div-Toggle-ExampleImg-DornPositionDritteStufe-button(style="display: none;  align-items: center; justify-content: space-between;")                                                
                                label#labelDornPositionDritteStufe(class="form__label", for="dornPositionZweiteStufe") Thorn- Position third step (mm) --> Measure the thorn with a ruler...!  
                                button.btn.btn--info.toggle-ExampleImg-DornPositionDritteStufe-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-DornPositionDritteStufe-container(style="display: none;")
                                div(class="form__group") Example
                                    img#imgDornPositionDritteStufe(src='/img/RezepteBilderASMAG/DreiStufenDornMessenErsteBisD.png', alt='img DreiStufenDornMessenErsteBisD')
                                    br    
                                    br                                 
                            input#dornPositionDritteStufe(class="form__input", type="number", style="display: none;" placeholder="e.g. 65 (+ 1mm to 2mm additionally longer in the thorn-area of thin wall thickness)",required="required" min="10" max="99" onblur="validateDornPositionDritteStufe(this)")                                    
                            br
                            br
                        div(class="form__group" id="groupDornStufenWerte1Button" style="display: none;") 
                            button.btn.btn--green(id="nextButtonDornStufenWerte1" type="button" onclick="saveDataDornStufenWerte()") Next
                            a.btn-space
                            a.btn-space
                            a.btn.btn--small.btn--gray(href=`/api/v1/createRecipeOverview` id="cancelButtonDornWerte1") Cancel

                        div(class="form__group") Multiple- Length- Data
                            div#div-Toggle-ExampleImg-Fixlaenge-button(style="display: none;  align-items: center; justify-content: space-between;")                        
                                label#labelFixlaenge(class="form__label", for="fixlaenge") Fixed- length (mm)
                                button.btn.btn--info.toggle-ExampleImg-Fixlaenge-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-Fixlaenge-container(style="display: none;")
                                div(class="form__group") Example
                                    img#imgFixlaenge(src='/img/RezepteBilderASMAG/BeispielFixlaenge.png', alt='img BeispielFixlaenge')
                                    br    
                                    br                                  
                            input#fixlaenge(class="form__input", type="number", style="display: none;" placeholder="e.g. 1360",required="required" min="30" max="2500" onblur="validateFixlaenge(this)")    
                        div(class="form__group")
                            div#div-Toggle-ExampleImg-AusgleichstueckBreite-button(style="display: none;  align-items: center; justify-content: space-between;")                        
                                label#labelAusgleichstueck(class="form__label", for="ausgleichstueck") Compensation- piece (mm)
                                button.btn.btn--info.toggle-ExampleImg-AusgleichstueckBreite-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-AusgleichstueckBreite-container(style="display: none;")
                                div(class="form__group") Example
                                    img#imgAusgleichstueckBreite(src='/img/RezepteBilderASMAG/ZwischenStückBreite.png', alt='img ZwischenStückBreite')
                                    br    
                                    br                               
                            input#ausgleichstueck(class="form__input", type="number", style="display: none;" placeholder="e.g. 30 (30 is standard, otherwise 50)",required="required" min="1" max="100" onblur="validateAusgleichstueck(this)")
                        div(class="form__group")
                            div#div-Toggle-ExampleImg-Mehrfachlaenge-button(style="display: none;  align-items: center; justify-content: space-between;")                        
                                label#labelMehrfachlaenge(class="form__label", for="mehrfachlaenge") Multiple- length (mm, doesn't have to be that precise)
                                button.btn.btn--info.toggle-ExampleImg-Mehrfachlaenge-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-Mehrfachlaenge-container(style="display: none;")
                                div(class="form__group") Example
                                    img#imgMehrfachlaenge(src='/img/RezepteBilderASMAG/BeispielMehrfachlänge.png', alt='img BeispielMehrfachlänge')
                                    br    
                                    br                               
                            input#mehrfachlaenge(class="form__input", type="number", style="display: none;" placeholder="e.g. 8500",required="required" min="5000" max="13000" onblur="validateMehrfachlaenge(this)")
                        div(class="form__group")
                            div#div-Toggle-ExampleImg-AnzahlFixlaengenProMFL-button(style="display: none;  align-items: center; justify-content: space-between;")                        
                                label#labelAnzahlFixlaengenProMehrfachlaenge(class="form__label", for="anzahlFixlaengenProMehrfachlaenge") Number of fixed- lengths per multiple- length (plus 1 additionally, bei 6 --> 7)
                                button.btn.btn--info.toggle-ExampleImg-AnzahlFixlaengenProMFL-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-AnzahlFixlaengenProMFL-container(style="display: none;")
                                div(class="form__group") Example
                                    img#imgAnzahlFixlaengenProMFL(src='/img/RezepteBilderASMAG/AnzahlFixlängenProMFL.png', alt='img AnzahlFixlängenProMFL')
                                    br    
                                    br                                
                            input#anzahlFixlaengenProMehrfachlaenge(class="form__input", type="number", style="display: none;" placeholder="e.g. 5  + 1 additionally", required="required", min="3", max="25", onblur="validateAnzahlFixlaengenProMehrfachlaenge(this)")
                            br
                            br
                        div(class="form__group" id="groupMehrfachlaengenDatenButton" style="display: none;")    
                            button.btn.btn--green(id="nextButtonMehrfachlaengenDaten" type="button" onclick="saveDataMehrfachlaengenDaten()") Next
                            a.btn-space
                            a.btn-space
                            a.btn.btn--small.btn--gray(href=`/api/v1/createRecipeOverview` id="cancelButtonMehrfachlaengenDaten") Cancel

                        div(class="form__group") Tube- Values
                            label#labelMindestGutanteil(class="form__label", for="mindestGutanteil" style="display: none;") Minimum- goodshare (%)
                            input#mindestGutanteil(class="form__input", type="number", style="display: none;" value = 80, required="required", readOnly = true )
                        div(class="form__group")
                            div#div-Toggle-ExampleImg-ProfileGekoppelt-button(style="display: none;  align-items: center; justify-content: space-between;")                                                    
                                label#labelProfileGekoppelt(class="form__label", for="profileGekoppelt") Profile- coupled
