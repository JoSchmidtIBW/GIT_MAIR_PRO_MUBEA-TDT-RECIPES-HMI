            function validateDornPositionZweiteStufe(inputDornPositionZweiteStufe){
                console.log("bin validateDornPositionZweiteStufe")
                let dornPositionZweiteStufeInput = inputDornPositionZweiteStufe.value;
                if(dornPositionZweiteStufeInput > 99 || dornPositionZweiteStufeInput < 10){
                    displayMessage_isError_isSuccess('Invalid format entry by thorn- position- second- step. Please enter the numbers in the correct format.', true);
                    inputDornPositionZweiteStufe.value = '';
                }
            }

            function validateDornDurchmesserDritteStufe(inputDornDurchmesserDritteStufe){
                patternDornDurchmesserDritteStufe= /^(0[1-9]|[1-9][0-9]|1[0-9][0-9])[.](0[0-9]|1[0-9]|[2-9][0-9])$/;
                
                let minDornDurchmesserDritte= 15; 
