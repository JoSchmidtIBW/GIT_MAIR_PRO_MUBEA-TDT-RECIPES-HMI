extends base

block content 
    main.main 
        br
        .user-view
            .user-view__content
                .user-view__form-container
                    h2.heading-secondary.ma-bt-md Tři-stupně-4-BMSMB vytváření receptu
                    form.form.form-createRecipe-3_St_4_BMSMB-data
                        div(class="form__group")
                            .boxImg_CreateTemplate
                                img#img23_St_4_BMSMB_CreateTemplate(style="height: 200px; length: 400px; margin-left: 5px; margin-top: 5px; margin-bottom: 1px; margin-right: 5px;" src='/img/RezepteBilderASMAG/3_St_4_BMSMB_CreateVorlage.png', alt='img 3_St_4_BMSMB_CreateVorlage')
                        div(class="form__group") Data záhlaví
                            label(class="form__label", for="artikelNummer") Číslo artiklu / číslo materiálu                            
                            input#artikelNummer(class="form__input" type="number" placeholder="Např. 10191122" required="required" min="10000000" max="99999999" onblur="validateArtikelNummer(this)")
                        div(class="form__group")
                            label(class="form__label", for="artikelName") Název artiklu
                            input#artikelName(class="form__input", type="text", placeholder="Např. 24.50x3.80-3.20-2.60", required="required", pattern="^\\d{2}\\.\\d{2}x\\d\\.\\d{2}-\\d\\.\\d{2}-\\d\\.\\d{2}$", onblur="validateArtikelName(this)")
                        div(class="form__group")
                            label(class="form__label", for="ziehGeschwindigkeit") Rychlost tažení (m/min)
                            input#ziehGeschwindigkeit(class="form__input", type="number", placeholder="Např. 15",required="required" min="5" max="50" onblur="validateZiehGeschwindigkeit(this)")
                        
                        div(class="form__group")
                            label(class="form__label", for="vDornVor") Rychlost trnu vpřed (%)
                            input#vDornVor(class="form__input", type="number", placeholder="Např. 100", required="required" min="1" max="100" onblur="validateVDornVor(this)")
                            //div(class="form__group")
                            label(class="form__label", for="vDornZurueck") Rychlost trnu zpět (%)
                            input#vDornZurueck(class="form__input", type="number", placeholder="Např. 100", required="required" min="1" max="100" onblur="validateVDornZurueck(this)")                                                                        

                        div(class="form__group")
                            //-br
                            br
                            label(class="form__label", for="benutzerVorName") Jméno
                            input#benutzerID(class="form__input" type="hidden" value=user._id style="background-color: lightgreen;")
                            input#benutzerVorName(class="form__input" type="text" value=user.firstName readOnly=true style="background-color: #E8F0FE;")
                            br
                            label(class="form__label", for="benutzerNachName") Příjmení 
                            input#benutzerNachName(class="form__input" type="text" value=user.lastName readOnly=true style="background-color: #E8F0FE;") 
                        div(class="form__group")
                            button.btn.btn--green(id="nextButtonKopfdaten" type="button" onclick="saveDataKopfDaten()") Další
                            a.btn-space
                            a.btn-space
                            a.btn.btn--small.btn--gray(href=`/api/v1/createRecipeOverview` id="cancelButtonKopfdaten") Zrušit
                        
                        div(class="form__group") Hodnoty dornu
                            div#div-Toggle-ExampleImg-TDTAuftragMitVorzug-button(style="display: none;  align-items: center; justify-content: space-between;")                        
