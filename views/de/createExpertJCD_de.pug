                if (wandDickeEndeSelect) {
                    if (wandDickeEndeSelect.value === 'andere') {
                        wandDickeArr.push(wandDickeEndeInput);
                    } else {
                        wandDickeArr.push(wandDickeEndeSelect);
                    }
                }

                let isWandDickeInputsArrFilled = true;
                for(let i = 0; i<wandDickeArr.length; i++){
                    console.log("wandDickeArr[i]: " + wandDickeArr[i].value);
