                    }
                }

                for (let i = 0; i < wandDickeEigeneSelects.length; i++) {
                    let select = wandDickeEigeneSelects[i];
                    if (select.value === 'andere') {
                        let correspondingInput = document.getElementById(select.id.replace('Select', 'Input'));
                        wandDickeArr.push(correspondingInput);
                    } else {
                        wandDickeArr.push(wandDickeEigeneSelects[i]);
                    }
