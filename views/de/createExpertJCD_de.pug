extends base

block content 
    main.main 
        //- h2 ExpertJCD- Rezept-Erstellung 😎
        br
        .user-view
            //-nav.user-view__menu

            //-ul.side-nav
                    +navItem('#', 'My ASMA-error reports', 'user-error-report')

            .user-view__content
                .user-view__form-container
                    h2.heading-secondary.ma-bt-md 🕶️- Rezept- Erstellung als Experte -🕶️
                    br
                    form.form.form-createRecipe-ExpertJCD-data
                        div(class="form__group")
                            .boxImg_CreateTemplate
                                img#imgCreateExpertJCD_CreateTemplate(style="height: 400px; length: 400px; margin-left: 5px; margin-top: 5px; margin-bottom: 1px; margin-right: 5px;" src='/img/RezepteBilderASMAG/createExpertJCD_CreateVorlage3.png', alt='img Ranjip createExpertJCD_CreateVorlage2')
                        div(class="form__group") Kopf- Daten
                            label(class="form__label", for="artikelNummer") Artikelnummer / Materialnummer
                            input#artikelNummer(class="form__input" type="number" placeholder="zB. 10191122" required="required" min="10000000" max="99999999" onblur="validateArtikelNummer(this)")
                        div(class="form__group")
                            label(class="form__label", for="artikelName") Artikelname
                            input#artikelName(class="form__input", type="text", placeholder="zB. 19.50x3.55-2.75 oder 24.50x3.80-3.20-2.60", required="required", pattern="^(\\d{2}\\.\\d{2}x\\d\\.\\d{2}-\\d\\.\\d{2}(-\\d\\.\\d{2})?)|(\\d{2}\\.\\d{2}x\\d{2}\\.\\d{2}-\\d{2}\\.\\d{2}(-\\d{2}\\.\\d{2})?)$", onblur="validateArtikelName(this)")
                        div(class="form__group")
                            label(class="form__label", for="ziehGeschwindigkeit") Zieh- Geschwindigkeit (m/min)
                            input#ziehGeschwindigkeit(class="form__input", type="number", placeholder="zB. 15",required="required" min="5" max="50" onblur="validateZiehGeschwindigkeit(this)")
                        
                        div(class="form__group")
                            label(class="form__label", for="vDornVor") Dorn-Geschwindigkeit-Vor (%)
                            input#vDornVor(class="form__input", type="number", placeholder="zB. 100", required="required" min="1" max="100" onblur="validateVDornVor(this)")
                            //div(class="form__group")
                            label(class="form__label", for="vDornZurueck") Dorn-Geschwindigkeit-Zurück (%)
                            input#vDornZurueck(class="form__input", type="number", placeholder="zB. 100", required="required" min="1" max="100" onblur="validateVDornZurueck(this)")

                        div(class="form__group")
                            //-br
                            br
                            label(class="form__label", for="benutzerVorName") Vorname
                            input#benutzerID(class="form__input" type="hidden" value=user._id style="background-color: lightgreen;")
                            input#benutzerVorName(class="form__input" type="text" value=user.firstName readOnly=true style="background-color: #E8F0FE;")
                            br
                            label(class="form__label", for="benutzerNachName") Nachname 
                            input#benutzerNachName(class="form__input" type="text" value=user.lastName readOnly=true style="background-color: #E8F0FE;") 
                        div(class="form__group")
                            button.btn.btn--green(id="nextButtonKopfdaten" type="button" onclick="saveDataKopfDaten()") Weiter
                            a.btn-space
                            a.btn-space
                            a.btn.btn--small.btn--gray(href=`/api/v1/createRecipeOverview` id="cancelButtonKopfdaten") Abbrechen
                        
                        div(class="form__group") Dorn- Werte
                            div#div-Toggle-ExampleImg-TDTAuftragMitVorzug-button(style="display: none;  align-items: center; justify-content: space-between;")                        
                                label#labelRohrAussenDurchmesserLetzterZug(class="form__label", for="rohrAussenDurchmesserLetzterZug")
                                    | Einsatzrohr- Aussen-
                                    span.form__label-diameter-symbol &empty; (mm)
                                    |   (AD-Letzter Zug --> Vorzug beachten!)
                                button.btn.btn--info.toggle-ExampleImg-TDTAuftragMitVorzug-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-TDTAuftragMitVorzug-container(style="display: none;")
                                div(class="form__group") Beispiel
                                    img#imgTDTAuftragMitVorzug(src='/img/RezepteBilderASMAG/TDTAuftragMitVorzug.png', alt='img TDTAuftragMitVorzug')
                                    br    
                                    br                                        
                            input#rohrAussenDurchmesserLetzterZug(class="form__input", type="text", placeholder="zB. 41.00 (Vorzug beachten! zB. 31.00)",style="display: none;", required="required", pattern="^(0[1-9]|[1-9][0-9]|1[0-9][0-9])[.](0[0-9]|1[0-9]|[2-9][0-9])$", onblur="validateRohrAussenDurchmesserLetzterZug(this)")
                        div(class="form__group")
                            label#labelRohrWandDickeAussenDurchmesserLetzterZug(class="form__label", for="rohrWandDickeAussenDurchmesserLetzterZug" style="display: none;")
                                | Einsatzrohr- Wanddicke (mm)
                                |   (WD-Letzter Zug --> Vorzug beachten!)  
                            input#rohrWandDickeAussenDurchmesserLetzterZug(class="form__input", type="text", placeholder="zB. 5.60 (Vorzug beachten! zB. 4.20)",style="display: none;", required="required", pattern="^(0?[1-9]|9)[.](0[0-9]|1[0-9]|[2-9][0-9])$", onblur="validateRohrWandDickeAussenDurchmesserLetzterZug(this)")
                        div(class="form__group")
                            label#labelRohrInnenDurchmesserLetzterZugBerechnet(class="form__label", for="rohrInnenDurchmesserLetzterZugBerechnet" style="display: none;") Rohr- Innendurchmesser- letzter Zug berechnet (mm) (Aussendurchmesser - 2 x Wanddicke letzter Zug)
                            input#rohrInnenDurchmesserLetzterZugBerechnet(class="form__input", type="number", style="display: none;", required="required")     
                        div(class="form__group")
                            label#labelRohrAussenDurchmesserTDTZug(class="form__label", for="rohrAussenDurchmesserTDTZug" style="display: none;") Rohr- Aussendurchmesser- TDT- Zug (mm)
                            input#rohrAussenDurchmesserTDTZug(class="form__input", type="number", style="display: none;", required="required")
                        div(class="form__group")
                            div#div-Toggle-ExampleImg-BeispielAngel-button(style="display: none;  align-items: center; justify-content: space-between;")                                                
                                label#labelAngel(class="form__label", for="angel") Angel (mm)
                                button.btn.btn--info.toggle-ExampleImg-BeispielAngel-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-BeispielAngel-container(style="display: none;")
                                div(class="form__group") Beispiel
                                    img#imgBeispielAngel(src='/img/RezepteBilderASMAG/BeispielAngel.png', alt='img BeispielAngel')
                                    br    
                                    br                                      
                            input#angel(class="form__input", type="number", placeholder="150 (ist Standart)",style="display: none;", required="required", min="150" max="1000", onblur="validateAngel(this)")    
                            br
                            br
                        div(class="form__group" id="groupDornWerte1Button" style="display: none;")
                            button.btn.btn--green(id="nextButtonDornWerte1" type="button" onclick="saveDataDornWerte1()" ) Weiter
                            a.btn-space
                            a.btn-space
                            a.btn.btn--small.btn--gray(href=`/api/v1/createRecipeOverview` id="cancelButtonDornWerte1") Abbrechen
                        
                        div(class="form__group") Dorn- Stufen
                            div#div-Toggle-ExampleImg-DornDurchmesserErsteStufe-button(style="display: none;  align-items: center; justify-content: space-between;")                                                    
                                label#labelDornDurchmesserErsteStufe(class="form__label", for="dornDurchmesserErsteStufe")= `Dorndurchmesser erste Stufe (mm) (theoretisch: ${dornDurchmesserErsteStufeBerechnet} )`
                                button.btn.btn--info.toggle-ExampleImg-DornDurchmesserErsteStufe-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-DornDurchmesserErsteStufe-container(style="display: none;")
                                div(class="form__group") Beispiel
                                    img#imgDornDurchmesserErsteStufe(src='/img/RezepteBilderASMAG/DornDurchmesserErsteStufe.png', alt='img DornDurchmesserErsteStufe')
                                    br    
                                    br   
                            input#dornDurchmesserErsteStufe(class="form__input", type="text", style="display: none;" placeholder="Kleinster Durchmesser",required="required"  pattern="^(0[1-9]|[1-9][0-9]|1[0-9][0-9])[.](0[0-9]|1[0-9]|[2-9][0-9])$" onblur="validateDornDurchmesserErsteStufe(this)")        
                        div(class="form__group")
                            label#labelDornPositionErsteStufe(class="form__label", for="dornPositionErsteStufe" style="display: none;") Dorn- Position erste Stufe (mm)                             
                            input#dornPositionErsteStufe(class="form__input", type="number",readOnly = true, style="display: none;" placeholder="",required="required" value='0' min="0" max="0" )
                            //onblur="validateDornPositionErsteStufe(this)"    
                        div(class="form__group")
                            div#div-Toggle-ExampleImg-DornDurchmesserZweiteStufe-button(style="display: none;  align-items: center; justify-content: space-between;")                                                                             
                                label#labelDornDurchmesserZweiteStufe(class="form__label", for="dornDurchmesserZweiteStufe")= `Dorndurchmesser zweite Stufe (mm) (theoretisch: ${dornDurchmesserZweiteStufeBerechnet} )`
                                button.btn.btn--info.toggle-ExampleImg-DornDurchmesserZweiteStufe-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-DornDurchmesserZweiteStufe-container(style="display: none;")
                                div(class="form__group") Beispiel
                                    img#imgDornDurchmesserZweiteStufe(src='/img/RezepteBilderASMAG/DornDurchmesserZweiteStufe.png', alt='img DornDurchmesserZweiteStufe')
                                    br    
                                    br                                 
                            input#dornDurchmesserZweiteStufe(class="form__input", type="text", style="display: none;" placeholder="Mittlerer Durchmesser",required="required", pattern="^(0[1-9]|[1-9][0-9]|1[0-9][0-9])[.](0[0-9]|1[0-9]|[2-9][0-9])$" onblur="validateDornDurchmesserZweiteStufe(this)")    
                        div(class="form__group")
                            div#div-Toggle-ExampleImg-DornPositionZweiteStufe-button(style="display: none;  align-items: center; justify-content: space-between;")                                                    
                                label#labelDornPositionZweiteStufe(class="form__label", for="dornPositionZweiteStufe") Dorn- Position zweite Stufe (mm) --> Dorn mit Massstab messen...!
                                button.btn.btn--info.toggle-ExampleImg-DornPositionZweiteStufe-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-DornPositionZweiteStufe-container(style="display: none;")
                                div(class="form__group") Beispiel
                                    img#imgDornPositionZweiteStufe(src='/img/RezepteBilderASMAG/ZweiStufenDornMessen.png', alt='img ZweiStufenDornMessen')
                                    br    
                                    br                                    
                            input#dornPositionZweiteStufe(class="form__input", type="number", style="display: none;" placeholder="+ 1 bis 2mm zusätzlich (länger) beim Dornbereich der mittleren Wanddicke",required="required" min="10" max="99" onblur="validateDornPositionZweiteStufe(this)")                                    
                        div(class="form__group")
                            div#div-Toggle-ExampleImg-DornDurchmesserDritteStufe-button(style="display: none;  align-items: center; justify-content: space-between;")                                                    
                                label#labelDornDurchmesserDritteStufe(class="form__label", for="dornDurchmesserZweiteStufe")= `Dorndurchmesser dritte Stufe (mm) (theoretisch: ${dornDurchmesserDritteStufeBerechnet} )`
                                button.btn.btn--info.toggle-ExampleImg-DornDurchmesserDritteStufe-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-DornDurchmesserDritteStufe-container(style="display: none;")
                                div(class="form__group") Beispiel
                                    img#imgDornDurchmesserDritteStufe(src='/img/RezepteBilderASMAG/DornDurchmesserDritteStufe3STD.png', alt='img DornDurchmesserDritteStufe3STD')
                                    br    
                                    br                                
                            input#dornDurchmesserDritteStufe(class="form__input", type="text", style="display: none;" placeholder="Grösster Durchmesser",required="required", pattern="^(0[1-9]|[1-9][0-9]|1[0-9][0-9])[.](0[0-9]|1[0-9]|[2-9][0-9])$" onblur="validateDornDurchmesserDritteStufe(this)")    
                        div(class="form__group")
                            div#div-Toggle-ExampleImg-DornPositionDritteStufe-button(style="display: none;  align-items: center; justify-content: space-between;")                                                
                                label#labelDornPositionDritteStufe(class="form__label", for="dornPositionZweiteStufe") Dorn- Position dritte Stufe (mm) --> Dorn mit Massstab messen...!  
                                button.btn.btn--info.toggle-ExampleImg-DornPositionDritteStufe-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-DornPositionDritteStufe-container(style="display: none;")
                                div(class="form__group") Beispiel
                                    img#imgDornPositionDritteStufe(src='/img/RezepteBilderASMAG/DreiStufenDornMessenErsteBisD.png', alt='img DreiStufenDornMessenErsteBisD')
                                    br    
                                    br                                
                            input#dornPositionDritteStufe(class="form__input", type="number", style="display: none;" placeholder="+ 1 bis 2mm zusätzlich (länger) beim Dornbereich der dünnen Wanddicke",required="required" min="10" max="99" onblur="validateDornPositionDritteStufe(this)")                                    
                            br
                            br
                        div(class="form__group" id="groupDornStufenWerte1Button" style="display: none;") 
                            //div(class="form__group" id="groupDornStufenWerte1Button" )    
                            button.btn.btn--green(id="nextButtonDornStufenWerte1" type="button" onclick="saveDataDornStufenWerte()") Weiter
                            a.btn-space
                            a.btn-space
                            a.btn.btn--small.btn--gray(href=`/api/v1/createRecipeOverview` id="cancelButtonDornWerte1") Abbrechen

                        div(class="form__group") Mehrfachlängen- Daten
                            div#div-Toggle-ExampleImg-Fixlaenge-button(style="display: none;  align-items: center; justify-content: space-between;")                        
                                label#labelFixlaenge(class="form__label", for="fixlaenge") Fixlänge (mm)
                                button.btn.btn--info.toggle-ExampleImg-Fixlaenge-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-Fixlaenge-container(style="display: none;")
                                div(class="form__group") Beispiel
                                    img#imgFixlaenge(src='/img/RezepteBilderASMAG/BeispielFixlaenge.png', alt='img BeispielFixlaenge')
                                    br    
                                    br                                
                            input#fixlaenge(class="form__input", type="number", style="display: none;" placeholder="zB. 1360", required="required" min="30" max="2500" onblur="validateFixlaenge(this)")    
                        div(class="form__group")
                            div#div-Toggle-ExampleImg-AusgleichstueckBreite-button(style="display: none;  align-items: center; justify-content: space-between;")                        
                                label#labelAusgleichstueck(class="form__label", for="ausgleichstueck") Ausgleichstück / Zwischenstück (mm)
                                button.btn.btn--info.toggle-ExampleImg-AusgleichstueckBreite-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-AusgleichstueckBreite-container(style="display: none;")
                                div(class="form__group") Beispiel
                                    img#imgAusgleichstueckBreite(src='/img/RezepteBilderASMAG/ZwischenStückBreite.png', alt='img ZwischenStückBreite')
                                    br    
                                    br                                  
                            input#ausgleichstueck(class="form__input", type="number", style="display: none;" placeholder="zB. 30 (30 ist Standart, ansonsten 50)", required="required" min="1" max="100" onblur="validateAusgleichstueck(this)")
                        div(class="form__group")
                            div#div-Toggle-ExampleImg-Mehrfachlaenge-button(style="display: none;  align-items: center; justify-content: space-between;")                        
                                label#labelMehrfachlaenge(class="form__label", for="mehrfachlaenge") Mehrfachlänge (mm, muss nicht so genau sein)
                                button.btn.btn--info.toggle-ExampleImg-Mehrfachlaenge-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-Mehrfachlaenge-container(style="display: none;")
                                div(class="form__group") Beispiel
                                    img#imgMehrfachlaenge(src='/img/RezepteBilderASMAG/BeispielMehrfachlänge.png', alt='img BeispielMehrfachlänge')
                                    br    
                                    br                              
                            input#mehrfachlaenge(class="form__input", type="number", style="display: none;" placeholder="zB. 8500", required="required" min="5000" max="13000" onblur="validateMehrfachlaenge(this)")
                        div(class="form__group")
                            div#div-Toggle-ExampleImg-AnzahlFixlaengenProMFL-button(style="display: none;  align-items: center; justify-content: space-between;")                        
                                label#labelAnzahlFixlaengenProMehrfachlaenge(class="form__label", for="anzahlFixlaengenProMehrfachlaenge") Anzahl Fixlängen pro Mehrfachlänge (plus 1 zusätzlich, bei 6 --> 7)
                                button.btn.btn--info.toggle-ExampleImg-AnzahlFixlaengenProMFL-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
                                    a(style="color: green; margin-top: 2px; margin-bottom: 10px; margin-left: 1px; vertical-align: middle; display: inline-block; ")  Info
                            .exampleImg-AnzahlFixlaengenProMFL-container(style="display: none;")
                                div(class="form__group") Beispiel
                                    img#imgAnzahlFixlaengenProMFL(src='/img/RezepteBilderASMAG/AnzahlFixlängenProMFL.png', alt='img AnzahlFixlängenProMFL')
                                    br    
                                    br                                
                            input#anzahlFixlaengenProMehrfachlaenge(class="form__input", type="number", style="display: none;" placeholder="zB. 5  + 1 zusätzlich", required="required", min="3", max="25", onblur="validateAnzahlFixlaengenProMehrfachlaenge(this)")
                            br
                            br
                        div(class="form__group" id="groupMehrfachlaengenDatenButton" style="display: none;")    
                            button.btn.btn--green(id="nextButtonMehrfachlaengenDaten" type="button" onclick="saveDataMehrfachlaengenDaten()") Weiter
                            a.btn-space
                            a.btn-space
                            a.btn.btn--small.btn--gray(href=`/api/v1/createRecipeOverview` id="cancelButtonMehrfachlaengenDaten") Abbrechen

                        div(class="form__group") Rohr- Werte
                            label#labelMindestGutanteil(class="form__label", for="mindestGutanteil" style="display: none;") Mindest- Gutanteil (%)
                            input#mindestGutanteil(class="form__input", type="number", style="display: none;" value = 80, required="required", readOnly = true )
                        div(class="form__group")
                            div#div-Toggle-ExampleImg-ProfileGekoppelt-button(style="display: none;  align-items: center; justify-content: space-between;")                                                    
                                label#labelProfileGekoppelt(class="form__label", for="profileGekoppelt") Profile gekoppelt
                                button.btn.btn--info.toggle-ExampleImg-ProfileGekoppelt-button(type="button" style="margin-left: 20px; margin-bottom: 10px; ")
                                    svg(class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;")
                                        use(xlink:href="/img/icons.svg#icon-info" style="color: green; ")
