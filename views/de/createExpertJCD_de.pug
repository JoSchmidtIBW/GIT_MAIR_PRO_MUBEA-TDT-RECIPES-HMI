                        console.log("Hat leeres!!!");
                        isWandDickeInputsArrFilled = false;
                        break;
                    }
                }

                if (!isEigenePositionInputsArrFilled) {
                    alert('Für "Weiter6" müssen die Positionen richtig ausgefüllt werden!');
                }
                else {
                    let isValidOrder = true;
                    let isDifferenceValid = true;

                    for (let i = 1; i < eigenePositionInputsArr.length; i++) {
                        let current = parseFloat(eigenePositionInputsArr[i].value);
                        let previous = parseFloat(eigenePositionInputsArr[i - 1].value);

                        if (current <= previous) {
                            isValidOrder = false;    
                            eigenePositionInputsArr[i].value = '';                    
                            break; 
                        }

                        if (current - previous < 1) {
                            isDifferenceValid = false;
                            eigenePositionInputsArr[i].value = '';
                            eigenePositionInputsArr[i - 1].value = '';
                            break;
                        }
                    }

                    if (!isValidOrder) {
                        alert('Die Position ist falsch oder muss grösser sein als die vorherige!');
                    } else if (!isDifferenceValid) {
