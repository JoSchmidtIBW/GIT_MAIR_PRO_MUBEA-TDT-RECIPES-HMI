        script.
            let artikelNummer = '';
            let artikelName = '';

            let wanddickeBig = '';
            let wanddickeMiddle = '';
            let wanddickeSmall = '';

            let dornDurchmesserErsteStufeBerechnet = '';
            let dornDurchmesserZweiteStufeBerechnet = '';
            let dornDurchmesserDritteStufeBerechnet = '';

            let fixlaengeEnde = '';

            function displayMessage_isError_isSuccess(message, isError) {
                const markup = `<div class="alert ${isError ? 'alert--error' : 'alert--success'}" >${message}</div>`;

                const tempElement = document.createElement('div');
                tempElement.innerHTML = markup;

                const messageElement = tempElement.firstElementChild;

                document.body.insertBefore(messageElement, document.body.firstChild);

                setTimeout(() => {
                    messageElement.remove();
                }, 2500);
            }

            function removeEckeSection(sectionCount) {
                const sectionToRemove = document.getElementById('eigeneEcke' + sectionCount);
                if (sectionToRemove) {
                    sectionToRemove.remove();

                    const allEcke = document.querySelectorAll('[id^="eigeneEcke"]');
                    for (let i = 0; i < allEcke.length; i++) {
                        const ecke = allEcke[i];
                        const eckeNummer = parseInt(ecke.id.replace('eigeneEcke', ''));
                        if (eckeNummer > sectionCount) {
                            const aEckeE = ecke.querySelector('.form__label[id^="aEckeE"]');
                            const labelWanddicke = ecke.querySelector('.form__label[id^="labelWanddickeEcke"]');
                            const labelPosition = ecke.querySelector('.form__label[id^="labelPositionEcke"]');
                            if (labelWanddicke && labelPosition && aEckeE) {
                                labelWanddicke.textContent = (eckeNummer - 1) + ' - Wanddicke - ' + (eckeNummer - 1);
                                labelPosition.textContent = (eckeNummer - 1) + ' - Position - ' + (eckeNummer - 1);
                                aEckeE.textContent = 'Eigene Ecke-' + (eckeNummer - 1);
                            }
                            ecke.id = 'eigeneEcke' + (eckeNummer - 1);
                            const btnMinus = ecke.querySelector('.btn--eckeMinus');
                            if (btnMinus) {
                                btnMinus.setAttribute('onclick', `removeEckeSection(${eckeNummer - 1})`);
                            }
                        }
                    }
                }
            }

            function updateSectionCount(container) {
                const sections = container.querySelectorAll('.form__group[id^="eigeneEcke"]');
                console.log("sections: " + sections)
                sections.forEach((section, index) => {
                    const newSectionId = `eigeneEcke${index + 1}`;
                    const aEckeE = section.querySelector(`#aEckeE${index + 1}`);
                    const labelWanddicke = section.querySelector(`#labelWanddickeEcke${index + 1}`);
                    const labelPosition = section.querySelector(`#labelPositionEcke${index + 1}`);
                    if (labelWanddicke && labelPosition && aEckeE) {  
                        labelWanddicke.textContent = `${index + 1} - Wanddicke - ${index + 1}`;
                        labelPosition.textContent = `${index + 1} - Position - ${index + 1}`;
                        aEckeE.textContent = `Eigene Ecke-${index + 1}`;
                    }
                    const btnMinus = section.querySelector('.btn--eckeMinus');
                    if (btnMinus) {
                        btnMinus.setAttribute('onclick', `removeEckeSection(${index + 1})`);
                    }
                    section.id = newSectionId;
                });
            }

            function addEckeSection() {
                const containerEigeneEcke = document.getElementById('eigeneEckeContainer');
                const sectionCount = containerEigeneEcke.querySelectorAll('.form__group[id^="eigeneEcke"]').length + 1;
                const newSection = document.createElement('div');
                const newSectionId = `eigeneEcke${sectionCount}`;
                console.log("sectionCount: " + sectionCount);
                newSection.id = newSectionId;
                newSection.style.display = 'none';

                newSection.innerHTML = `
                                        <div class="form__group" id="eigeneEckeE" align-items: center; justify-content: space-between;>

                                        
                                        <div style="display: flex; align-items: center; justify-content: space-between;">
                                            <a class="form__label" id="aEckeE${sectionCount}">Eigene Ecke-${sectionCount}</a>
                                            <button class="btn btn--eckeMinus" id="eckeMinusBtn${sectionCount}" type="button" style="margin-left: 385px; margin-bottom: 0px;" onclick="removeEckeSection('${newSectionId}')">
                                                <svg class="heading-box__icon" style="margin-left: 0px; margin-top: 2px; height: 15px; length: 15px;">
                                                    <use xlink:href="/img/icons.svg#icon-minus" style="color: white;"></use>
                                                </svg>
                                            </button>
                                            <a class="aEckeLoeschen" style="color: green; margin-top: 2px; margin-bottom: 3px; margin-left: 7px; vertical-align: middle; display: inline-block;"> Ecke löschen</a>
                                        </div>
                                        
                                        <label class="form__label" id="labelWanddickeEcke${sectionCount}" for="wanddickeEcke${sectionCount}">${sectionCount} - Wanddicke - ${sectionCount}</label>
                                        <select class="form__input" id="eigeneWandDickeSelectEigene${sectionCount}" onchange="wandDickeOnChangeEigene(this, '${sectionCount}')"> </select>
                                        
                                        <input class="form__input" id="eigeneWandDickeInputEigene${sectionCount}" type="text" style="display: none;" placeholder="Eigene Wanddicke eingeben" pattern="^(0?[1-9]|9)[.](0[0-9]|1[0-9]|[2-9][0-9])$" onblur="validateEigeneWanddicke(this)"/>
                                        <br />
                                        <label class="form__label" id="labelPositionEcke${sectionCount}" for="positionEcke${sectionCount}">${sectionCount} - Position - ${sectionCount}</label>
                                        <input class="form__input" id="positionEcke${sectionCount}" type="number" min="10" max="2500" required="required" onblur="validateEckenPositionMinMaxX(this)" />
                                        
                                        </div>
                                        <br />
                `;                        

                containerEigeneEcke.appendChild(newSection);
                newSection.style.display = 'block';
                updateSectionCount(containerEigeneEcke);

                const wandDickeSelectEigene = document.getElementById(`eigeneWandDickeSelectEigene${sectionCount}`);

                let optionen1 = "";

                let optionen2STD1 = {
                    [parseFloat(wanddickeBig).toFixed(2)]: parseFloat(wanddickeBig).toFixed(2),
                    [parseFloat(wanddickeSmall).toFixed(2)]: parseFloat(wanddickeSmall).toFixed(2),
                    "andere": "Andere"
                };
                
                let optionen3STD1 = {
                    [parseFloat(wanddickeBig).toFixed(2)]: parseFloat(wanddickeBig).toFixed(2),
                    [parseFloat(wanddickeMiddle).toFixed(2)]: parseFloat(wanddickeMiddle).toFixed(2),
                    [parseFloat(wanddickeSmall).toFixed(2)]: parseFloat(wanddickeSmall).toFixed(2),
                    "andere": "Andere"
                };

                if(wanddickeMiddle === "") {
                    optionen1 = optionen2STD1;
                } else {
                    optionen1 = optionen3STD1;
                }

                for (let key in optionen1) {
                    if (optionen1.hasOwnProperty(key)) {
                        const optionElement1 = document.createElement("option");
                        optionElement1.value = optionen1[key].toLowerCase();
                        optionElement1.textContent = optionen1[key];
                        wandDickeSelectEigene.appendChild(optionElement1);
                    }
                }
            }

            document.addEventListener("change", function(event) {
                if (event.target && event.target.id.startsWith("eigeneWandDickeSelectEigene")) {
                    const sectionCount = event.target.id.replace("eigeneWandDickeSelectEigene", "");
                    wandDickeOnChangeEigene(event.target, sectionCount);
                }
            });            

            function wandDickeOnChangeEigene(select, sectionCount) {
                console.log("bin wandDickeOnChangeEigene und sectionCount: " + sectionCount)
                let eigeneWandDickeInputEigene = document.getElementById(`eigeneWandDickeInputEigene${sectionCount}`);

                if (!eigeneWandDickeInputEigene) {
                    console.error('Input-Elemente nicht gefunden');
                    return;
                }

                if (select.value === "andere") {
                    console.log("andere")
                    eigeneWandDickeInputEigene.style.display = "block";
                    eigeneWandDickeInputEigene.setAttribute("required", "true");
                } else {
                    console.log("Nicht andere")
                    eigeneWandDickeInputEigene.style.display = "none";
                    eigeneWandDickeInputEigene.removeAttribute("required");
                    eigeneWandDickeInputEigene.value = "";
                }
            }

            function validateEigeneWanddicke(inputEigeneWanddicke){
                console.log("bin validateEigeneWanddicke")
                let patternEigeneWanddicke= /^(0?[1-9]|9)[.](0[0-9]|1[0-9]|[2-9][0-9])$/;
                
                let minEigeneWanddicke = wanddickeSmall; 
                let maxEigeneWanddicke = wanddickeBig;

                if(patternEigeneWanddicke.test(inputEigeneWanddicke.value)){
                    let eigeneWanddickeStr = inputEigeneWanddicke.value;
                    let eigeneWanddickeFloatInput = parseFloat(eigeneWanddickeStr);
                    console.log("eigeneWanddickeFloatInput: "+eigeneWanddickeFloatInput)

                    if(eigeneWanddickeFloatInput < minEigeneWanddicke ){
                        displayMessage_isError_isSuccess('Eingabe Wanddicke zu klein!', true);
                        inputEigeneWanddicke.value = '';     
                    } else if(eigeneWanddickeFloatInput > maxEigeneWanddicke) {
                        displayMessage_isError_isSuccess('Eingabe Wanddicke zu gross!', true);
                        inputEigeneWanddicke.value = '';    
                    }
                } 
                else {
                    displayMessage_isError_isSuccess('Ungültiges Format-Eingabe bei Wanddicke. Bitte geben Sie die Zahlen im richtigen Format ein.', true);
                    inputEigeneWanddicke.value = ''; 
                }   
            }


            function validateArtikelNummer(inputArtikelNummer) {
                console.log("Bin validateArtikelNummer")
                let regexArtikelNummer = /^\d{8}$/;

                if (!regexArtikelNummer.test(inputArtikelNummer.value)) {
                    displayMessage_isError_isSuccess('Die Artikelnummer muss aus einer 8-stelligen Zahl bestehen!', true);
                    inputArtikelNummer.value = ''; 
                }
            }

            function validateZiehGeschwindigkeit(inputZiehGeschwindigkeit) {
                console.log("Bin validateZiehGeschwindigkeit")
                let zgMax = 50;
                let zgMin = 5;

                if (inputZiehGeschwindigkeit.value > 50 || inputZiehGeschwindigkeit.value < 5) {
                    displayMessage_isError_isSuccess('Eingabe Ziehgeschwindigkeit muss kontrolliert werden!', true);
                    inputZiehGeschwindigkeit.value = ''; 
                }
            }

            function validateVDornVor(inputVDornVor) {
                console.log('Bin validateVDornVor');
                let vDornFwdMax = 100;
                let vDornFwdMin = 1;

                if(inputVDornVor.value < vDornFwdMin){
                    displayMessage_isError_isSuccess('V-Dorn-Vor zu klein!', true);
                    inputVDornVor.value = ''; 
                } else if(inputVDornVor.value > vDornFwdMax){
                    displayMessage_isError_isSuccess('V-Dorn-Vor zu gross!', true);
                    inputVDornVor.value = ''; 
                }                
            }

            function validateVDornZurueck(inpurVDornZurueck) {
                console.log('Bin validateVDornZurueck');
                let vDornBwdMax = 100;
                let vDornBwdMin = 1; 

                if(inpurVDornZurueck.value < vDornBwdMin){
                    displayMessage_isError_isSuccess('V-Dorn-Zurück zu klein!', true);
                    inpurVDornZurueck.value = ''; 
                } else if(inpurVDornZurueck.value > vDornBwdMax){
                    displayMessage_isError_isSuccess('V-Dorn-Zurück zu gross!', true);
                    inpurVDornZurueck.value = ''; 
                }                   
            }            

            function validateArtikelName(inputArtikelName) {
                console.log('bin validateArtikelName: ' + inputArtikelName.value)
                
                let isPatternZwei = false;
                let isPatternDrei = false;
                let patternZwei = /^\d{2}\.\d{2}x\d\.\d{2}-\d\.\d{2}$/;
                let patternDrei = /^\d{2}\.\d{2}x\d\.\d{2}-\d\.\d{2}-\d\.\d{2}$/;

                if (patternZwei.test(inputArtikelName.value)) {
                    console.log("bin Pattern-Zwei, 2");
                    isPatternZwei = true;
                    console.log(isPatternZwei);

                    let artikelNameArr = inputArtikelName.value.split(/x|-/);
                    let rohrDurchmesser = parseFloat(artikelNameArr[0])
                    console.log("rohrDurchmesser: "+rohrDurchmesser)
                    let ersteWanddicke = parseFloat(artikelNameArr[1]);
                    console.log("ersteWanddicke: "+ersteWanddicke)
                    wanddickeBig = ersteWanddicke;
                    console.log("wanddickeBig: "+wanddickeBig)
                    let zweiteWanddicke = parseFloat(artikelNameArr[2]);
                    console.log("zweiteWanddicke: "+zweiteWanddicke)
                    wanddickeSmall = zweiteWanddicke;
                    console.log("wanddickeMiddle: "+wanddickeMiddle)

                    dornDurchmesserErsteStufeBerechnet = parseFloat(rohrDurchmesser - (2 * ersteWanddicke));
                    console.log("dornDurchmesserErsteStufeBerechnet: "+dornDurchmesserErsteStufeBerechnet);
                    document.getElementById('labelDornDurchmesserErsteStufe').innerText = `Dorndurchmesser erste Stufe (mm) (theoretisch: ${parseFloat(dornDurchmesserErsteStufeBerechnet).toFixed(2)})`;
                    document.getElementById('dornDurchmesserErsteStufe').placeholder = `${parseFloat(dornDurchmesserErsteStufeBerechnet).toFixed(2)} theoretisch (kleinster Durchmesser)`;

                    let imgDornDurchmesserErsteStufeBeiZwei = document.getElementById('imgDornDurchmesserErsteStufe');
                    imgDornDurchmesserErsteStufeBeiZwei.src = '/img/RezepteBilderASMAG/DornDurchmesserErsteStufe.png';
                    imgDornDurchmesserErsteStufeBeiZwei.alt = 'img DornDurchmesserErsteStufe';

                    dornDurchmesserZweiteStufeBerechnet = parseFloat(rohrDurchmesser - (2 * zweiteWanddicke));
                    console.log("dornDurchmesserZweiteStufeBerechnet: "+dornDurchmesserZweiteStufeBerechnet);
                    document.getElementById('labelDornDurchmesserZweiteStufe').innerText = `Dorndurchmesser zweite Stufe (mm) (theoretisch: ${parseFloat(dornDurchmesserZweiteStufeBerechnet).toFixed(2)})`;
                    document.getElementById('dornDurchmesserZweiteStufe').placeholder = `${parseFloat(dornDurchmesserZweiteStufeBerechnet).toFixed(2)} theoretisch (grösster Durchmesser)`;
                    document.getElementById('dornPositionZweiteStufe').placeholder = `zB. 47 (+ 1mm bis 2mm zusätzlich länger beim Dornbereich der dünnen Wanddicke)`;

                    let imgDornDurchmesserZweiteStufeBeiZwei = document.getElementById('imgDornDurchmesserZweiteStufe');
                    imgDornDurchmesserZweiteStufeBeiZwei.src = '/img/RezepteBilderASMAG/DornDurchmesserZweiteStufe.png';
                    imgDornDurchmesserZweiteStufeBeiZwei.alt = 'img DornDurchmesserZweiteStufe';

                    let imgDornPositionZweiteStufeBeiZwei = document.getElementById('imgDornPositionZweiteStufe');
                    imgDornPositionZweiteStufeBeiZwei.src = '/img/RezepteBilderASMAG/ZweiStufenDornMessen.png';
                    imgDornPositionZweiteStufeBeiZwei.alt = 'img ZweiStufenDornMessen';                    

                    if(rohrDurchmesser<18 || rohrDurchmesser>48){
                        displayMessage_isError_isSuccess('Rohrdurchmesser kleiner als 18 oder grösser als 48!', true)
                        inputArtikelName.value = '';
                    }

                    if (ersteWanddicke <= zweiteWanddicke) {
                        displayMessage_isError_isSuccess('Die erste Wanddicke muss größer sein als die zweite mittlere Wanddicke!', true);
                        inputArtikelName.value = ''; 
                    }                   
                }

                if (patternDrei.test(inputArtikelName.value)) {
                    console.log("bin Pattern-Drei, 3");
                    isPatternDrei = true;
                    console.log(isPatternDrei);

                    let artikelNameArr = inputArtikelName.value.split(/x|-/);
                    let rohrDurchmesser = parseFloat(artikelNameArr[0])
                    console.log("rohrDurchmesser: "+rohrDurchmesser)
                    let ersteWanddicke = parseFloat(artikelNameArr[1]);
                    console.log("ersteWanddicke: "+ersteWanddicke)
                    wanddickeBig = ersteWanddicke;
                    console.log("wanddickeBig: "+wanddickeBig)
                    let zweiteWanddicke = parseFloat(artikelNameArr[2]);
                    console.log("zweiteWanddicke: "+zweiteWanddicke)
                    wanddickeMiddle = zweiteWanddicke;
                    console.log("wanddickeMiddle: "+wanddickeMiddle)
                    let dritteWanddicke = parseFloat(artikelNameArr[3]);
                    console.log("dritteWanddicke: "+dritteWanddicke)
                    wanddickeSmall = dritteWanddicke;
                    console.log("wanddickeSmall: "+wanddickeSmall)

                    dornDurchmesserErsteStufeBerechnet = parseFloat(rohrDurchmesser - (2 * ersteWanddicke));
                    console.log("dornDurchmesserErsteStufeBerechnet: "+dornDurchmesserErsteStufeBerechnet);
