extends base

block content
    main.main.BackgroundImageSPS
        br
        div(style='float: right; margin-right: 100px;')
            .sps__logo
                img(src='/img/sps/Beckhoff_Logo.svg.png', alt='Beckhoff_Logo', style="filter: drop-shadow(gray 1rem 1rem 8px);")

        if (dataPingSPS.includes('Ping zur SPS fehlgeschlagen'))
            h2 Ping- Ergebnis
            pre(style='font-size: 11px; color: #323232;')= dataPingSPS        

        .container-flexSPS(style="display: flex; flex-wrap: wrap; gap: 10px;")
            .sectionSPS(style="flex: 1; min-width: 380px;")
                button.toggle-PingResult-button(type="button" style="opacity: 0.8;")
                    a(style="color: black;") Info Ping
                .container-PingResult(style="display: none;")
                    div.form__group
                        h4 Ping- Ergebnis
                        pre(style='font-size: 11px; color: #323232;')= dataPingSPS

        .container-flexSPS(style="display: flex; flex-wrap: wrap; gap: 10px;")
            .sectionSPS(style="flex: 1; min-width: 380px;")
                button.toggle-DeviceInfo-button(type="button" style="opacity: 0.8;")
                    a(style="color: black;") Info Device            
                .container-DeviceInfo(style="display: none;")
                    div.form__group
                        h4 DeviceInfo
                        pre(style='font-size: 11px; color: #323232;')= deviceInfo

            .sectionSPS(style="flex: 1; min-width: 380px;")
                button.toggle-UploadInfo-button(type="button" style="opacity: 0.8;")
                    a(style="color: black;") Info Upload            
                .container-UploadInfo(style="display: none;")
                    div.form__group
                        h4 UploadInfo- Ergebnis
                        pre(style='font-size: 11px; color: #323232;')= uploadInfo

            .sectionSPS(style="flex: 1; min-width: 380px;")
                button.toggle-SymbolVersion-button(type="button" style="opacity: 0.8;")
                    a(style="color: black;") Info Symbol-Version            
                .container-SymbolVersion(style="display: none;")
                    div.form__group
                        h4 SymbolVersion- Ergebnis
                        pre(style='font-size: 11px; color: #323232;')= symbolVersion

            .sectionSPS(style="flex: 1; min-width: 380px;")
                button.toggle-PlcRunTimeState-button(type="button" style="opacity: 0.8;")
                    //-svg(class="heading-box__icon" style="height: 15px;")
                        use(xlink:href="/img/icons.svg#icon-map-pin" style="color: green; ")
                    a(style="color: black; ") Info Plc-Run-Time-State            
                //-button.btn.btn--info.toggle-PlcRunTimeState-button(type="button")
                    svg(class="heading-box__icon" style="height: 15px;")
                        use(xlink:href="/img/icons.svg#icon-map-pin" style="color: green; ")
                    a(style="color: green;") Info Plc-Run-Time-State
                .container-PlcRunTimeState(style="display: none;")
                    div.form__group
                        h4 PlcRunTimeState- Ergebnis
                        pre(style='font-size: 11px; color: #323232;')= plcRunTimeState
        br

        .warning-SPSMomentcontainer
            span.moment-icon ⚠️
            .warning-textSPSMoment Achtung, dies ist eine Moment- Aufnahme!
            span.moment-icon ⚠️
        br    
        if error
            each err in error
                pre(style="background-color: #f8f8f8; border: 1px solid #e0e0e0; font-size: 12px; color: red; white-space: pre-wrap; word-wrap: break-word;")=JSON.stringify(err, null, 2)
                pre(style="background-color: #f8f8f8; border: 1px solid #e0e0e0; font-size: 12px; color: #323232;")=err.message
                //-pre(style="background-color: #f8f8f8; border: 1px solid #e0e0e0; font-size: 12px; color: #323232;")=err.stack
                //-pre(style="background-color: #f8f8f8; border: 1px solid #e0e0e0; font-size: 12px; color: #323232;") Es werden keine GVL- Daten geschickt!

        br
        table.tableSPS 
            div    
                div(style="font-size: 18px; font-weight: bold; background-color: #f1f3f4; margin-bottom: 1px; text-align: center;") GVL- Daten- SPS
                //div(style="background-color: #f1f3f457;")
                div(style="background-color: #f1f3f4bd;")
                    a(style="padding: 2px; font-size:14px; font-weight: bold;") Ziehpositionen:
                    button(style="float: right; " id="toggleButtonMatrix") X
                    //-div(style="padding: 3px;")
                        div.ziehpositionenScrollBox(style="padding: 5px;")= dataGVL && dataGVL.ziehpositionen ? JSON.stringify(dataGVL.ziehpositionen, null, 2) : 'Keine Ziehpositionen verfügbar'
                    //-br
                    div(style="padding: 3px;")
                        //div.ziehpositionenScrollBox(style="padding: 5px;")=JSON.stringify(dataGVL.ziehpositionen)            
                        //-dataGVL && dataGVL.ziehpositionen ? JSON.stringify(dataGVL.ziehpositionen) : 'Keine Ziehpositionen verfügbar'
                        div.ziehpositionenScrollBox(style="padding: 5px; font-size: 12px;" id="ziehpositionenContent")=dataGVL && dataGVL.ziehpositionen ? JSON.stringify(dataGVL.ziehpositionen) : 'Keine Ziehpositionen verfügbar'
                        //-div.ziehpositionenScrollBox(style="padding: 5px; font-size: 12px;" id="ziehpositionenContent")
                            if dataGVL && dataGVL.ziehpositionen
                                each item in dataGVL.ziehpositionen

                                    a(style=`color: ${item.Pos !== 0 || item.Verst !== 0 ? 'blue' : 'pink'};`) #{JSON.stringify(item)}
                            //-if dataGVL && dataGVL.ziehpositionen
                                each item in dataGVL.ziehpositionen
                                    - const pos = item.Pos || 0;
                                    - const verst = item.Verst || 0;
                                    div(style=`color: ${pos !== 0 || verst !== 0 ? 'blue' : 'pink'};`) Pos: #{pos}, Verst: #{verst}
                                    //-- const parsedItem = typeof item === 'string' ? JSON.parse(item) : item;
                                    //-div(style=`color: ${parsedItem.Pos !== 0 || parsedItem.Verst !== 0 ? 'blue' : 'pink'};`) #{JSON.stringify(parsedItem)}
                                    //-if item.Pos !== 0 || item.Verst !== 0
                                    //-if (item !== '"Pos":0,"Verst":0')
                                    //-if item.Pos !== 0 || item.Verst !== 0
                                    //-div(style=`color: ${item.Pos !== 0 || item.Verst !== 0 ? 'blue' : 'pink'};`) #{JSON.stringify(item)}
                                    //-     div(style="color: blue;") #{JSON.stringify(item)}
                                    //- else
                                    //-     div(style="color: pink;") #{JSON.stringify(item)}
                            else
                                div Keine Ziehpositionen verfügbar
