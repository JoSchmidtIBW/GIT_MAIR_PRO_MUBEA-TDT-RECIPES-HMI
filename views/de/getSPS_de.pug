        script.
            document.addEventListener('DOMContentLoaded', function() {
                const buttonTogglePingResult = document.querySelector('.toggle-PingResult-button');
                const containerPingResult = document.querySelector('.container-PingResult');

                buttonTogglePingResult.addEventListener('click', function() {
                    if (containerPingResult.style.display === 'none') {
                        containerPingResult.style.display = 'block';
                    } else {
                        containerPingResult.style.display = 'none';
                    }
                });   

                const buttonToggleDeviceInfo = document.querySelector('.toggle-DeviceInfo-button');
                const containerDeviceInfo = document.querySelector('.container-DeviceInfo');

                buttonToggleDeviceInfo.addEventListener('click', function() {
                    if (containerDeviceInfo.style.display === 'none') {
                        containerDeviceInfo.style.display = 'block';
                    } else {
                        containerDeviceInfo.style.display = 'none';
                    }
                });   

                const buttonToggleUploadInfo = document.querySelector('.toggle-UploadInfo-button');
                const containerUploadInfo = document.querySelector('.container-UploadInfo');

                buttonToggleUploadInfo.addEventListener('click', function() {
                    if (containerUploadInfo.style.display === 'none') {
                        containerUploadInfo.style.display = 'block';
                    } else {
                        containerUploadInfo.style.display = 'none';
                    }
                });   

                const buttonToggleSymbolVersion = document.querySelector('.toggle-SymbolVersion-button');
                const containerSymbolVersion = document.querySelector('.container-SymbolVersion');

                buttonToggleSymbolVersion.addEventListener('click', function() {
                    if (containerSymbolVersion.style.display === 'none') {
                        containerSymbolVersion.style.display = 'block';
                    } else {
                        containerSymbolVersion.style.display = 'none';
                    }
                });   

                const buttonTogglePlcRunTimeState = document.querySelector('.toggle-PlcRunTimeState-button');
                const containerPlcRunTimeState = document.querySelector('.container-PlcRunTimeState');

                buttonTogglePlcRunTimeState.addEventListener('click', function() {
                    if (containerPlcRunTimeState.style.display === 'none') {
                        containerPlcRunTimeState.style.display = 'block';
                    } else {
                        containerPlcRunTimeState.style.display = 'none';
                    }
                });         
            });    

            let isToggledMatrix = false;
            const toggleButtonMatrix = document.getElementById('toggleButtonMatrix');
            const ziehPositionenDiv = document.getElementById('ziehpositionenContent');

            toggleButtonMatrix.addEventListener('click', function() {
                    if (isToggledMatrix) {
                        ziehPositionenDiv.style.backgroundColor = '#f1f3f4bd';
                        ziehPositionenDiv.style.color = 'black';
                    } else {
                        ziehPositionenDiv.style.backgroundColor = 'black';
                        ziehPositionenDiv.style.color = '#00ff41';
                    }
                    isToggledMatrix = !isToggledMatrix;
            });            

