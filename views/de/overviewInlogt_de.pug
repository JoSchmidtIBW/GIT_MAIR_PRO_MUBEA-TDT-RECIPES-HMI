            });  

            let isToggledHackerMatrix = false;
            const toggleButtonHackerMatrix = document.getElementById('toggleButtonHackerMatrix');
            const csvDataContainer = document.getElementById('csvDataContainer');
            const textCSVData = document.getElementById('CSVDataLocalStorage');

            toggleButtonHackerMatrix.addEventListener('click', function() {
                    if (isToggledHackerMatrix) {
                        csvDataContainer.style.backgroundColor = 'lightgrey';
                        csvDataContainer.style.color = 'pink';
                        toggleButtonHackerMatrix.style.file = 'opacity(0.5);';
