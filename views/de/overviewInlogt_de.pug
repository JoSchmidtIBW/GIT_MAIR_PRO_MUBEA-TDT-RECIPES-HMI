           const linkSPSa_OPCUA = document.getElementById("sps-btn-a_OPCUA");
            
            function spinnerFunction_OPCUA() {
                console.log('Bin SpinnerFunction_OPCUA');                
                document.getElementById("sps-btn-svg_OPCUA").innerHTML = `<svg ><use class="loaderSPS" xlink:href="/img/icons.svg#icon-loader"></use></svg>`                
                window.location.href = linkSPSa_OPCUA.href;
            }


            function spinnerFunctionSPS_OPCUA() {
                console.log('Bin spinnerFunctionSPS_OPCUA'); 
                const duration = 30; 
                let remainingTime = duration;

                window.location.href = "/api/v1/getSPS_OPCUA";

                btnSPS_OPCUA.innerHTML = `
                <a>
                    <svg  style="height: 50px; width: 40px; padding-bottom: 5px; margin-left: -8px; margin-bottom: -33px;" viewBox="0 0 40 40">
                    <!-- Kreis -->
                    <circle cx="20" cy="8" r="9" stroke="#747474"  stroke-width="3" fill="none" stroke-dasharray="3 4" class="loaderRecipe"></circle>
                    <!-- Countdown-Text -->
                    <text x="50%" y="21%" text-anchor="middle" fill="#747474" dy=".3em" font-size="12px">${remainingTime}</text>

                    </svg>
                    SPS_OPC-UA
                </a>
                `;
                //    <use xlink:href="/img/icons.svg#icon-upload" style="color: #5d5d5d; "></use>
                const interval = setInterval(() => {
                    remainingTime--;
                    const textElement = btnSPS_OPCUA.querySelector('text');
                    if (textElement) {
                        textElement.textContent = remainingTime;
                    }

                    if (remainingTime <= 0) {
                        clearInterval(interval);
                        //btnSPS_OPCUA.innerHTML = "hoihoi";
                        btnSPS_OPCUA.innerHTML = `
                            <svg class="heading-box__icon" id="sps-btn-svg_OPCUA" style="margin-left: 0px; margin-top: 2px; height: 24px; length: 24px;">
                            <use xlink:href="/img/icons.svg#icon-upload" style="color: #5d5d5d; "></use>
                            </svg><a id="sps-btn-a_OPCUA" href="/api/v1/getSPS_OPCUA" style="color: #747474; font-weight: 500; margin-top: 0px; margin-bottom: 16px; margin-left: 1px; margin-right: 5px; vertical-align: middle; display: inline-block; ">SPS_OPC-UA</a>
                        `;                        

                    }
                }, 1000);

                //btnSPS_OPCUA.innerHTML = "halllo";

            }            


            const btnRecipeSend = document.getElementById("recipeSendBtn");
            btnRecipeSend.addEventListener("click", spinnerFunctionRecipeSend);



            function spinnerFunctionRecipeSend() {
                const duration = 5; 
                let remainingTime = duration;

                btnRecipeSend.innerHTML = `
                <a>
                    <svg  style="height: 50px; width: 40px; margin-left: -8px; margin-bottom: -33px;" viewBox="0 0 40 40">
                    <!-- Kreis -->
                    <circle cx="20" cy="8" r="12" stroke="#FFF"  stroke-width="3" fill="none" stroke-dasharray="3 4" class="loaderRecipe"></circle>
                    <!-- Countdown-Text -->
                    <text x="50%" y="21%" text-anchor="middle" fill="#FFF" dy=".3em" font-size="12px">${remainingTime}</text>
                    </svg>
                    Rezept senden
                </a>
                `;

                

                const interval = setInterval(() => {
                    remainingTime--;
                    const textElement = btnRecipeSend.querySelector('text');
                    if (textElement) {
                        textElement.textContent = remainingTime;
                    }

                    if (remainingTime <= 0) {
                        clearInterval(interval);
                        btnRecipeSend.innerHTML = "Rezept senden";
                    }
                }, 1000);
            }            

            const btnSPSa = document.getElementById("sps-btn");
            btnSPSa.addEventListener("click", spinnerFunction);



