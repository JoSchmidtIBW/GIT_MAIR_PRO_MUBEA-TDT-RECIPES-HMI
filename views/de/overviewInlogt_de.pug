            const recipeDataContainer = document.getElementById('recipeDataContainer');
            const textRecipefindLoadedinSPS = document.getElementById('recipefindLoadedinSPSinDBrightDiv');

            toggleButtonHackerMatrixRecipe.addEventListener('click', function() {
                    if (isToggledHackerMatrixRecipe) {
                        recipeDataContainer.style.backgroundColor = 'rgb(243, 239, 239)';
                        toggleButtonHackerMatrixRecipe.style.file = 'opacity(0.5);';
