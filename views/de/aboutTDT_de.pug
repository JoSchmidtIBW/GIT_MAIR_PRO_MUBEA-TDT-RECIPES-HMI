        br
        br           

        script.
            document.addEventListener("DOMContentLoaded", () => {
                const ants = document.querySelectorAll(".ants");
                let timers = [];

                function resetAnts() {

                    ants.forEach(el => el.style.display = "none");

                    timers.forEach(t => clearTimeout(t));
                    timers = [];


                    timers.push(setTimeout(() => {
                        document.getElementById("ant6").style.display = "inline";
                    }, 5000));


                    timers.push(setTimeout(() => {
                        document.getElementById("ant8").style.display = "inline";
                    }, 10000));

                    timers.push(setTimeout(() => {
                        document.getElementById("ant5").style.display = "inline";
                    }, 15000));

                    timers.push(setTimeout(() => {
                        document.getElementById("ant1").style.display = "inline";
                    }, 20000));

                    timers.push(setTimeout(() => {
                        document.getElementById("ant7").style.display = "inline";
                    }, 25000));

                    timers.push(setTimeout(() => {
                        document.getElementById("ant2").style.display = "inline";
                    }, 30000));

                    timers.push(setTimeout(() => {
                        document.getElementById("ant3").style.display = "inline";
                    }, 35000));

                    timers.push(setTimeout(() => {
                        document.getElementById("ant4").style.display = "inline";
                    }, 37000));
                }

                resetAnts();

                document.addEventListener("mousemove", resetAnts);
            });
