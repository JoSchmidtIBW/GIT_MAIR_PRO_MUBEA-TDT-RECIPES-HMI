extends base

mixin navItem(link, text, icon, active)
    li(class=`${active ? 'side-nav--active' : ''}`)
        a(href=`${link}`)
            svg
                use(xlink:href=`/img/icons.svg#icon-${icon}`)
            | #{text}

block content
    main.main
        .user-view
            nav.user-view__menu

                ul.side-nav
                    +navItem('/api/v1/me', 'Meine Einstellungen', 'settings', false)
                    +navItem('/api/v1/myRecipeSend', 'Meine Aufträge', 'folder-plus', false)
                    +navItem('/api/v1/recipesSendSPSLog', 'Rezept-SPS-Sendeverlauf', 'search', false)
                    +navItem('/api/v1/recipesStatistic', 'Rezept-Statistik', 'trending-up', false)                    

                - if(user.role === 'admin' || user.role === 'Chef')
                    .admin-nav
                        h5.admin-nav__heading CHEF
                        ul.side-nav
                            +navItem('/api/v1/txt_xml_fileuploader', 'txt-xml-Drag-&-Drop', 'file-plus', false)

                - if(user.role === 'admin' || user.role === 'Chef')
                    .admin-nav
                        h5.admin-nav__heading= `${user.role}`
                        ul.side-nav
                            +navItem('/api/v1/manage_users', 'Benutzerverwaltung', 'users', true)


            .user-view__content1
                .user-view__form-container1
                    div(class="user-view__content")
                        div(class="user-view__form-container")
                            h1(style="color: red;") Als ADMIN
                            br
                            h2.heading-secondary.ma-bt-md= `Bearbeitender Benutzer: ${data.userToUpdate.firstName} ${data.userToUpdate.lastName}  `
                                svg(class="heading-box__icon" style="margin-left: 0px; margin-bottom: -3px; height: 24px; length: 24px;")
                                    use(xlink:href="/img/icons.svg#icon-edit" style="color: green; ")                            
                            form.form.form-workerAdmin-data
                                div(class="form__group ma-bt-md")
                                    input#userId(class="form__input", type="hidden", value=data.userToUpdate._id, readonly, style="background-color: lightgrey;")
                                div(class="form__group")
                                    label(class="form__label", for="employeeNumber") Mitarbeiternummer
                                    input#employeeNumber(class="form__input", type="number", value=data.userToUpdate.employeeNumber, readonly, style="background-color: lightgrey;")
                                div(class="form__group")
                                    label(class="form__label", for="firstname") Vorname
                                    input#firstname(class="form__input", type="text", value=data.userToUpdate.firstName)
                                div(class="form__group")
                                    label(class="form__label", for="lastname") Nachname
                                    input#lastname(class="form__input", type="text", value=data.userToUpdate.lastName)
                                div(class="form__group")
                                    label(class="form__label", for="professional") Beruf (fiktional)
                                    input#professional(class="form__input", type="text", value=data.userToUpdate.professional)
                                div(class="form__group")
                                    label(class="form__label", for="email") E-Mail
                                    input#email(class="form__input", type="email", value=data.userToUpdate.email)
                                div(class="form__group ma-bt-md")
                                    label(class="form__label", for="password") Passwort
                                    input#password(class="form__input", type="text", value=data.userToUpdate.password, readonly, style="background-color: lightgrey;")
                                div(class="form__group ma-bt-md")
                                    label(class="form__label", for="passwordEncripted") Entschlüsseltes Passwort
                                    input#passwordEncripted(class="form__input", type="text", value=data.userDecryptedPassword, readonly, style="background-color: lightgrey;")
                                div(class="form__group")
                                    label(class="form__label", for="language") Sprache
                                    input#language(class="form__input", type="text", value=data.userToUpdate.language, readonly, style="background-color: lightgrey;")
                                div(class="form__group")
                                    label(class="form__label", for="role") Rolle
                                    select#role(class="form__input")
                                        option(value=data.userToUpdate.role, selected, style="background-color: #98B7E1; color: white;") #{data.userToUpdate.role}
                                        option(value="Chef", selected=data.userToUpdate.role === 'Chef') Chef
                                        //-option(value="Schichtleiter", selected=data.userToUpdate.role === 'Schichtleiter') Schichtleiter
                                        option(value="user", selected=data.userToUpdate.role === 'user') User
                                        //-option(value="Unterhalt", selected=data.userToUpdate.role === 'Unterhalt') Unterhalt

                                div(class="form__group")
                                    label(class="form__label", for="departments") Abteilungen (fiktional)

                                    each departmentOption in [ 'Schweisserei', 'Zieherei', 'Anarbeit', 'Engineering', 'Konstruktion', 'Unterhalt', 'IT', 'Operations', 'Geschäfts-Führung' ]
                                        - var checked = data.userToUpdate.department && data.userToUpdate.department.includes(departmentOption)

                                        label(class="form__checkbox-label" style="display: block; margin-bottom: 10px;border: none;")
                                            input#department(class="form__checkbox-box", type="checkbox", name="departments", value=departmentOption, checked=checked,  style="width: 20px; height: 20px;")
                                            span(class="form__checkbox-name", style="font-size: 1.5rem;") #{departmentOption}           

                                br
                                div
                                    button.btn.btn--small.btn--green.btn--saveUpdateUserByAdmin Speichern
                                    a.btn-space(id="spaceBtn")
                                    a.btn-space(id="spaceBtn")
                                    button.btn.btn--small.btn--red(id="btn--questionDeleteUser", onclick="deleteUser()") Löschen
                                    a.btn-space(id="spaceBtn")
                                    a.btn-space(id="spaceBtn")
                                    a.btn.btn--small.btn--gray(href=`/api/v1/manage_users` id="cancelBtn") Abbrechen
                                    br
                                    br
                                    br
                                    br

                                div(class="form__group--deleteUser" style="display:none;")
                                    label(class="form__label", for="deleteUser" style="color: red") Nutzer löschen:
                                    br
                                    h2=`${data.userToUpdate.employeeNumber}`
                                    h1=`${data.userToUpdate.firstName} ${data.userToUpdate.lastName}`
                                    h2=`${data.userToUpdate.role}`
                                    br
                                br
                                div(class="form__group" id="reallyDeleteUser", style="display: none")
                                    h1(id="h--deleteQuestionText" style="color: red;") Wollen Sie den Nutzer wirklich löschen?
                                        svg(class="heading-box__icon" style="margin-left: 8px; margin-bottom: -3px; height: 24px; length: 24px;")
                                            use(xlink:href="/img/icons.svg#icon-trash-2" style="color: red; ")                                    
                                    br
                                    button.btn.btn--small.btn--red.btn--deleteUser(class="btn--deleteUpdateUserByAdmin") Löschen
                                    a.btn-space(id="spaceBtn")
                                    a.btn-space(id="spaceBtn")
                                    a.btn-space(id="spaceBtn")
                                    a.btn-space(id="spaceBtn")
                                    a.btn.btn--small.btn--gray.btn--cancel(id="btn--cancel", onclick="cancelDeleteUser()") Abbrechen


                                script.
                                    console.log("bin Skript")
                                    function getSelectedDepartments () {
                                        const departmentCheckboxes = document.querySelectorAll('input[name="departments"]');
                                        let selectedDepartments = [];
                                        departmentCheckboxes.forEach((checkbox) => {
                                            if (checkbox.checked) {
                                                selectedDepartments.push(checkbox.value);
                                            }
                                        });
                                        if (selectedDepartments.length > 0) {
                                            console.log(selectedDepartments + " sind angewählt");
                                            //alert("Department gewählt: "+ selectedDepartments)
                                            document.querySelector('#department').value = selectedDepartments;
                                        } else {
                                            console.log(selectedDepartments.length + " Departments!!!");
                                            alert('Bitte wählen Sie mindestens eine Abteilung aus.');
                                        }
                                    }

                                    document.querySelector('.btn--saveUpdateUserByAdmin').addEventListener('click', () => {
                                        getSelectedDepartments();
                                    });

                                    function deleteUser(){
                                        console.log("bin deleteUser")
                                        document.querySelector('.form__group--deleteUser').style.display = 'block';
                                        document.querySelector('.form__group--deleteUser').style.background = 'repeating-linear-gradient(-55deg, #ff0202 1px, #f7eaea 2px, #FFFFFF 7px, #FFFFFF 10px)';

                                        document.getElementById('btn--questionDeleteUser').style.display = 'none';
                                        document.getElementById('reallyDeleteUser').style.display = 'block';
                                        document.getElementById('cancelBtn').style.display = 'none';
                                    }

                                    function cancelDeleteUser(){
                                        console.log('bin cancelDeleteUser')
                                        document.querySelector('.form__group--deleteUser').style.display = 'none';
                                        document.getElementById('reallyDeleteUser').style.display = 'none';
                                        document.getElementById('btn--questionDeleteUser').style.display = 'inline-block';
                                        document.getElementById('cancelBtn').style.display = 'inline-block';
                                        document.getElementById('spaceBtn').style.display = 'inline-block';
                                    }